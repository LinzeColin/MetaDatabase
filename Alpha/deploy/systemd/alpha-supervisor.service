[Unit]
Description=Alpha 监督进程(心跳判活;失联即杀开关+告警)
After=postgresql.service

[Service]
User=alpha
WorkingDirectory=/opt/alpha/MetaDatabase/Alpha
EnvironmentFile=/opt/alpha/env
ExecStart=/opt/alpha/venv/bin/python -m backend.app.workers.main_supervisor
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
