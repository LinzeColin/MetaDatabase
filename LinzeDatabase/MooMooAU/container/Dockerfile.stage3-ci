FROM python:3.12.13-slim-bookworm@sha256:d50fb7611f86d04a3b0471b46d7557818d88983fc3136726336b2a4c657aa30b

LABEL org.opencontainers.image.title="MooMooAU Stage 3 validation image" \
      org.opencontainers.image.description="Synthetic validation only; not a production runtime image"

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/moomooau
COPY requirements/stage2.lock requirements/stage2.lock
RUN python -m pip install --no-cache-dir --require-hashes -r requirements/stage2.lock

COPY pyproject.toml ./
COPY src ./src
RUN python -m pip install --no-cache-dir --no-build-isolation --no-deps .

ENTRYPOINT ["python", "-m", "moomooau_archive.cli"]
