{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU Stage 2 Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "stage_id",
    "task_id",
    "stage_acceptance_id",
    "observed_at_utc",
    "baseline_commit",
    "record_status",
    "delivery_status",
    "checks",
    "linked_final_acceptance",
    "prohibition_counters",
    "next_action"
  ],
  "properties": {
    "schema_version": {"const": "moomooau.stage2-evidence.v1"},
    "evidence_id": {"type": "string", "pattern": "^S2-T020[1-7]-[A-Z0-9_-]+$"},
    "stage_id": {"const": "S2"},
    "task_id": {"pattern": "^T020[1-7]$"},
    "stage_acceptance_id": {"pattern": "^S2AC-00[1-7]$"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "baseline_commit": {"const": "932e3970490f87fd46671bc6a461340a339887ef"},
    "record_status": {"enum": ["PASS", "FAIL"]},
    "delivery_status": {"const": "LOCAL_ONLY_NOT_PUBLISHED"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_ref"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["PASS", "FAIL"]},
          "evidence_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "linked_final_acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "reason"],
        "properties": {
          "id": {"pattern": "^AC-[0-9]{3}$"},
          "status": {"enum": ["PARTIAL", "NOT_RUN"]},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "prohibition_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_gmail_calls",
        "gmail_mutations",
        "private_repository_calls",
        "real_secrets_read",
        "protected_key_deliveries",
        "external_writes",
        "remote_publication"
      ],
      "properties": {
        "real_gmail_calls": {"const": 0},
        "gmail_mutations": {"const": 0},
        "private_repository_calls": {"const": 0},
        "real_secrets_read": {"const": 0},
        "protected_key_deliveries": {"const": 0},
        "external_writes": {"const": 0},
        "remote_publication": {"const": 0}
      }
    },
    "next_action": {"type": "string", "minLength": 1}
  }
}
