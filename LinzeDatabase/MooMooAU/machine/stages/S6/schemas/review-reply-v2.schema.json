{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU isolated independent review reply v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "target",
    "review_mode",
    "verdict",
    "dimensions",
    "findings",
    "limitations",
    "sensitive_data_observed",
    "production_or_protected_claimed",
    "summary"
  ],
  "properties": {
    "schema_version": {"const": "moomooau.independent-review-reply.v2"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_commit",
        "candidate_commit",
        "candidate_tree",
        "request_sha256"
      ],
      "properties": {
        "baseline_commit": {"pattern": "^[0-9a-f]{40}$"},
        "candidate_commit": {"pattern": "^[0-9a-f]{40}$"},
        "candidate_tree": {"pattern": "^[0-9a-f]{40}$"},
        "request_sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "review_mode": {"const": "READ_ONLY_INDEPENDENT"},
    "verdict": {"enum": ["PASS", "FAIL"]},
    "dimensions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_refs", "rationale"],
        "properties": {
          "id": {"enum": ["SCOPE", "EVIDENCE_QUALITY", "FAILURE_HONESTY", "ROLLBACK"]},
          "status": {"enum": ["PASS", "FAIL"]},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "status", "finding", "evidence_refs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {"enum": ["BLOCKING", "HIGH", "MEDIUM", "LOW"]},
          "status": {"enum": ["OPEN", "RESOLVED"]},
          "finding": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "required_fix": {"type": "string", "minLength": 1},
          "resolution_ref": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"const": "OPEN"}}},
            "then": {"required": ["required_fix"]}
          },
          {
            "if": {"properties": {"status": {"const": "RESOLVED"}}},
            "then": {"required": ["resolution_ref"]}
          }
        ]
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "sensitive_data_observed": {"const": false},
    "production_or_protected_claimed": {"const": false},
    "summary": {"type": "string", "minLength": 1}
  }
}
