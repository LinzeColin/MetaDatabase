{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU candidate-bound local execution receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "subject",
    "scope",
    "environment",
    "commands",
    "raw_logs_retained",
    "sensitive_data_observed",
    "production_or_protected_executed",
    "remote_service_writes",
    "ephemeral_local_outputs_removed"
  ],
  "properties": {
    "schema_version": {"const": "moomooau.candidate-execution-receipt.v1"},
    "receipt_id": {"const": "S6-RMD05-CANDIDATE-GATES"},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "project_path",
        "baseline_commit",
        "candidate_commit",
        "candidate_tree",
        "clean_detached_checkout"
      ],
      "properties": {
        "repository": {"const": "MetaDatabase"},
        "project_path": {"const": "LinzeDatabase/MooMooAU"},
        "baseline_commit": {"pattern": "^[0-9a-f]{40}$"},
        "candidate_commit": {"pattern": "^[0-9a-f]{40}$"},
        "candidate_tree": {"pattern": "^[0-9a-f]{40}$"},
        "clean_detached_checkout": {"const": true}
      }
    },
    "scope": {"const": "LOCAL_SYNTHETIC_ONLY"},
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "python",
        "dependency_lock_path",
        "dependency_lock_sha256",
        "governance_commit",
        "python_executable_sha256"
      ],
      "properties": {
        "platform": {"type": "string", "minLength": 1},
        "python": {"pattern": "^3\\.12\\.[0-9]+$"},
        "dependency_lock_path": {"const": "requirements/stage6.lock"},
        "dependency_lock_sha256": {"pattern": "^[0-9a-f]{64}$"},
        "governance_commit": {"pattern": "^[0-9a-f]{40}$"},
        "python_executable_sha256": {"pattern": "^[0-9a-f]{64}$"}
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "working_directory",
          "argv",
          "tool_versions",
          "exit_code",
          "raw_stdout_bytes",
          "raw_stderr_bytes",
          "raw_stdout_sha256",
          "raw_stderr_sha256",
          "sanitized_stdout",
          "sanitized_stderr",
          "sanitized_stdout_sha256",
          "sanitized_stderr_sha256",
          "result_summary"
        ],
        "properties": {
          "id": {"pattern": "^[a-z0-9][a-z0-9-]+$"},
          "working_directory": {"const": "LinzeDatabase/MooMooAU"},
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "tool_versions": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string",
              "minLength": 1,
              "not": {
                "pattern": "(?:/Users/|/home/|/private/tmp/|/var/folders/|[A-Za-z]:\\\\Users\\\\)"
              }
            }
          },
          "exit_code": {"const": 0},
          "raw_stdout_bytes": {"type": "integer", "minimum": 0},
          "raw_stderr_bytes": {"type": "integer", "minimum": 0},
          "raw_stdout_sha256": {"pattern": "^[0-9a-f]{64}$"},
          "raw_stderr_sha256": {"pattern": "^[0-9a-f]{64}$"},
          "sanitized_stdout": {"type": "string"},
          "sanitized_stderr": {"type": "string"},
          "sanitized_stdout_sha256": {"pattern": "^[0-9a-f]{64}$"},
          "sanitized_stderr_sha256": {"pattern": "^[0-9a-f]{64}$"},
          "result_summary": {"type": "string", "minLength": 1}
        }
      }
    },
    "raw_logs_retained": {"const": false},
    "sensitive_data_observed": {"const": false},
    "production_or_protected_executed": {"const": false},
    "remote_service_writes": {"const": 0},
    "ephemeral_local_outputs_removed": {"const": true}
  }
}
