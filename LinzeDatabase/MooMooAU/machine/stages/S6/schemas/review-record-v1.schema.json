{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU Stage 6 Independent Review Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "stage_id",
    "baseline_commit",
    "reviewer_task",
    "model_family",
    "review_mode",
    "initial_verdict",
    "final_verdict",
    "dimensions",
    "findings",
    "conditions",
    "reviewed_at_utc",
    "summary"
  ],
  "properties": {
    "schema_version": {"const": "moomooau.independent-review.v1"},
    "review_id": {"pattern": "^S6-REVIEW-[A-Z0-9_-]+$"},
    "stage_id": {"const": "S6"},
    "baseline_commit": {"const": "2b8625a83e69093b9dce989f4eb964556e1b5fa2"},
    "reviewer_task": {"type": "string", "minLength": 1},
    "model_family": {"type": "string", "minLength": 1},
    "review_mode": {"const": "READ_ONLY_INDEPENDENT"},
    "initial_verdict": {"const": "FAIL"},
    "final_verdict": {"const": "CONDITIONAL_PASS"},
    "dimensions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "note"],
        "properties": {
          "id": {"enum": ["SCOPE", "EVIDENCE_QUALITY", "FAILURE_HONESTY", "ROLLBACK"]},
          "status": {"enum": ["PASS", "FAIL"]},
          "note": {"type": "string", "minLength": 1}
        }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "status", "finding", "resolution_ref"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "severity": {"enum": ["BLOCKING", "HIGH", "MEDIUM", "LOW"]},
          "status": {"enum": ["RESOLVED", "OPEN"]},
          "finding": {"type": "string", "minLength": 1},
          "resolution_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "reviewed_at_utc": {"type": "string", "format": "date-time"},
    "summary": {"type": "string", "minLength": 1}
  }
}
