{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU Stage 7 Preparation Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "stage_id",
    "task_id",
    "stage_acceptance_id",
    "observed_at_utc",
    "baseline_commit",
    "record_status",
    "scope",
    "delivery_status",
    "checks",
    "linked_final_acceptance",
    "production_oracles",
    "blockers",
    "prohibition_counters",
    "next_action"
  ],
  "properties": {
    "schema_version": {"const": "moomooau.stage7-evidence.v1"},
    "evidence_id": {"type": "string", "pattern": "^S7-T070[1-8]-[A-Z0-9_-]+$"},
    "stage_id": {"const": "S7"},
    "task_id": {"pattern": "^T070[1-8]$"},
    "stage_acceptance_id": {"pattern": "^S7AC-00[1-8]$"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "baseline_commit": {"const": "be8e196b03dcc475ed6261fbe20593b08bd26bcf"},
    "record_status": {"enum": ["READY", "BLOCKED"]},
    "scope": {"const": "LOCAL_SYNTHETIC_PREFLIGHT"},
    "delivery_status": {"const": "LOCAL_ONLY_NOT_PUBLISHED"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_ref"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"const": "PASS"},
          "evidence_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "linked_final_acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "reason"],
        "properties": {
          "id": {"pattern": "^AC-[0-9]{3}$"},
          "status": {"enum": ["PARTIAL", "NOT_RUN"]},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "production_oracles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "reason"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "status": {"enum": ["PASS", "FAILED", "NOT_RUN"]},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "protected_execution_receipt": {
      "enum": [
        "machine/stages/S7/reviews/t0702/execution-receipt.json",
        "machine/stages/S7/reviews/t0703/execution-receipt.json"
      ]
    },
    "blockers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "prohibition_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_gmail_calls",
        "gmail_mutations",
        "private_repository_calls",
        "real_secrets_read",
        "protected_key_deliveries",
        "external_writes",
        "remote_publication",
        "non_moomoo_full_reads",
        "non_moomoo_downloads",
        "non_moomoo_mutations",
        "raw_before_verification",
        "untrusted_content_execution",
        "model_real_data_calls",
        "model_secret_requests",
        "moomoo_portal_calls",
        "persistent_plaintext_objects",
        "thread_trash_calls",
        "permanent_delete_calls",
        "release_assets_above_one",
        "production_workflow_runs"
      ],
      "properties": {
        "real_gmail_calls": {"const": 0},
        "gmail_mutations": {"const": 0},
        "private_repository_calls": {"const": 0},
        "real_secrets_read": {"const": 0},
        "protected_key_deliveries": {"const": 0},
        "external_writes": {"const": 0},
        "remote_publication": {"const": 0},
        "non_moomoo_full_reads": {"const": 0},
        "non_moomoo_downloads": {"const": 0},
        "non_moomoo_mutations": {"const": 0},
        "raw_before_verification": {"const": 0},
        "untrusted_content_execution": {"const": 0},
        "model_real_data_calls": {"const": 0},
        "model_secret_requests": {"const": 0},
        "moomoo_portal_calls": {"const": 0},
        "persistent_plaintext_objects": {"const": 0},
        "thread_trash_calls": {"const": 0},
        "permanent_delete_calls": {"const": 0},
        "release_assets_above_one": {"const": 0},
        "production_workflow_runs": {"const": 0}
      }
    },
    "next_action": {"type": "string", "minLength": 1}
  }
}
