{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/moomooau/protected-m3-attempt-ledger-v1.schema.json",
  "title": "MooMooAU protected M3 attempt ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "task_id",
    "observed_through_utc",
    "attempts",
    "completion_policy",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "moomooau.protected-m3-attempt-ledger.v1"
    },
    "stage_id": {
      "const": "S7"
    },
    "task_id": {
      "const": "T0703"
    },
    "observed_through_utc": {
      "type": "string",
      "format": "date-time"
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/attempt"
      }
    },
    "completion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "same_head_rerun_allowed",
        "failed_head_redispatch_allowed",
        "repaired_exact_main_candidate_dispatch_allowed",
        "next_candidate_dispatch_limit",
        "t0704_authorized",
        "final_publication_authorized"
      ],
      "properties": {
        "same_head_rerun_allowed": {
          "const": false
        },
        "failed_head_redispatch_allowed": {
          "const": false
        },
        "repaired_exact_main_candidate_dispatch_allowed": {
          "type": "boolean"
        },
        "next_candidate_dispatch_limit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "t0704_authorized": {
          "const": false
        },
        "final_publication_authorized": {
          "const": false
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "t0703_complete",
        "s7ac_003_passed",
        "production_health",
        "final_acceptance",
        "stage7_complete"
      ],
      "properties": {
        "t0703_complete": {
          "type": "boolean"
        },
        "s7ac_003_passed": {
          "type": "boolean"
        },
        "production_health": {
          "const": false
        },
        "final_acceptance": {
          "const": false
        },
        "stage7_complete": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "status": {
      "enum": [
        "PASS",
        "FAILED"
      ]
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "started_at_utc",
        "completed_at_utc"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/status"
        },
        "started_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "delivery",
        "workflow",
        "jobs",
        "public_failure",
        "effects",
        "diagnosis"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "pull_request_number",
            "merge_commit_sha",
            "main_ci_runs_passed",
            "main_ci_runs_failed"
          ],
          "properties": {
            "kind": {
              "const": "CONTROLLED_MOOMOOAU_PR"
            },
            "pull_request_number": {
              "type": "integer",
              "minimum": 1
            },
            "merge_commit_sha": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "main_ci_runs_passed": {
              "type": "integer",
              "minimum": 0
            },
            "main_ci_runs_failed": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "run_id",
            "run_url",
            "event",
            "workflow_head_sha",
            "run_attempt",
            "reruns"
          ],
          "properties": {
            "run_id": {
              "type": "integer",
              "minimum": 1
            },
            "run_url": {
              "type": "string",
              "format": "uri",
              "pattern": "^https://github\\.com/LinzeColin/MetaDatabase/actions/runs/[1-9][0-9]*$"
            },
            "event": {
              "const": "workflow_dispatch"
            },
            "workflow_head_sha": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "run_attempt": {
              "const": 1
            },
            "reruns": {
              "const": 0
            }
          }
        },
        "jobs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authority_gate",
            "m3_budget_one",
            "identity_plaintext_cleanup"
          ],
          "properties": {
            "authority_gate": {
              "$ref": "#/$defs/job"
            },
            "m3_budget_one": {
              "$ref": "#/$defs/job"
            },
            "identity_plaintext_cleanup": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "status",
                "completed_at_utc"
              ],
              "properties": {
                "status": {
                  "const": "PASS"
                },
                "completed_at_utc": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          }
        },
        "public_failure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason_code",
            "failure_phase",
            "exact_root_cause_claimed",
            "production_health_claimed",
            "final_acceptance_claimed"
          ],
          "properties": {
            "status": {
              "const": "BLOCKED"
            },
            "reason_code": {
              "type": "string",
              "pattern": "^PROTECTED_M3_[A-Z_]+_FAILED$"
            },
            "failure_phase": {
              "type": "string",
              "minLength": 1
            },
            "installation_token_failure_class": {
              "enum": [
                "UNCLASSIFIED",
                "RESPONSE_SCOPE_REJECTED"
              ]
            },
            "exact_root_cause_claimed": {
              "const": false
            },
            "production_health_claimed": {
              "const": false
            },
            "final_acceptance_claimed": {
              "const": false
            }
          }
        },
        "effects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "private_repository_new_commits",
            "raw_ciphertext_creations",
            "processed_writes",
            "gmail_trash_messages_after_dispatch",
            "source_mutations",
            "timeline_writes",
            "scheduled_runs",
            "identity_plaintext_cleanup"
          ],
          "properties": {
            "private_repository_new_commits": {
              "type": "integer",
              "minimum": 0
            },
            "raw_ciphertext_creations": {
              "enum": [
                "ZERO_OBSERVED",
                "NONZERO_WITHIN_BUDGET",
                "NOT_VERIFIED"
              ]
            },
            "processed_writes": {
              "enum": [
                "ZERO_OBSERVED",
                "ONE_RECOVERED",
                "NOT_VERIFIED"
              ]
            },
            "gmail_trash_messages_after_dispatch": {
              "type": "integer",
              "minimum": 0
            },
            "source_mutations": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1
            },
            "timeline_writes": {
              "const": 0
            },
            "scheduled_runs": {
              "const": 0
            },
            "identity_plaintext_cleanup": {
              "const": "PASS"
            }
          }
        },
        "diagnosis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "observable_failure_boundary",
            "exact_root_cause",
            "high_confidence_defect",
            "basis"
          ],
          "properties": {
            "observable_failure_boundary": {
              "type": "string",
              "minLength": 1
            },
            "exact_root_cause": {
              "type": "string",
              "minLength": 1
            },
            "high_confidence_defect": {
              "type": "string",
              "minLength": 1
            },
            "basis": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
