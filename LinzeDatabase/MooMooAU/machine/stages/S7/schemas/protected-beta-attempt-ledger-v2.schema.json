{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MooMooAU T0702 protected Beta dispatch and execution ledger v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "task_id",
    "observed_through_utc",
    "rejected_dispatches",
    "attempts",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "moomooau.protected-beta-attempt-ledger.v2"
    },
    "stage_id": {
      "const": "S7"
    },
    "task_id": {
      "const": "T0702"
    },
    "observed_through_utc": {
      "const": "2026-07-23T22:53:05Z"
    },
    "rejected_dispatches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "#/$defs/rejected_dispatch"
      }
    },
    "attempts": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "$ref": "#/$defs/protected_attempt"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controlled_main_deliveries",
        "protected_beta_dispatches",
        "context_rejected_dispatches",
        "protected_workflow_runs",
        "workflow_reruns",
        "alpha_gate_passes",
        "beta_passes",
        "beta_failures",
        "identity_plaintext_cleanup_passes",
        "latest_outcome",
        "last_failure_phase",
        "last_installation_token_failure_class",
        "raw_archive_successful_runs",
        "gmail_mutations",
        "m3_runs",
        "processed_writes",
        "timeline_writes",
        "scheduled_runs",
        "t0702_complete",
        "m3_predecessor_satisfied",
        "m3_allowed",
        "m3_authority_status",
        "production_health_claimed",
        "final_acceptance_claimed"
      ],
      "properties": {
        "controlled_main_deliveries": {
          "const": 8
        },
        "protected_beta_dispatches": {
          "const": 12
        },
        "context_rejected_dispatches": {
          "const": 1
        },
        "protected_workflow_runs": {
          "const": 11
        },
        "workflow_reruns": {
          "const": 0
        },
        "alpha_gate_passes": {
          "const": 11
        },
        "beta_passes": {
          "const": 1
        },
        "beta_failures": {
          "const": 10
        },
        "identity_plaintext_cleanup_passes": {
          "const": 11
        },
        "latest_outcome": {
          "const": "PASS"
        },
        "last_failure_phase": {
          "const": "METADATA_VERIFICATION"
        },
        "last_installation_token_failure_class": {
          "const": "UNCLASSIFIED"
        },
        "raw_archive_successful_runs": {
          "const": 1
        },
        "gmail_mutations": {
          "const": 0
        },
        "m3_runs": {
          "const": 0
        },
        "processed_writes": {
          "const": 0
        },
        "timeline_writes": {
          "const": 0
        },
        "scheduled_runs": {
          "const": 0
        },
        "t0702_complete": {
          "const": true
        },
        "m3_predecessor_satisfied": {
          "const": true
        },
        "m3_allowed": {
          "const": false
        },
        "m3_authority_status": {
          "const": "WITHHELD_BY_CURRENT_OWNER_SCOPE"
        },
        "production_health_claimed": {
          "const": false
        },
        "final_acceptance_claimed": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "passed_job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "started_at_utc", "completed_at_utc"],
      "properties": {
        "status": {
          "const": "PASS"
        },
        "started_at_utc": {
          "$ref": "#/$defs/timestamp"
        },
        "completed_at_utc": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "beta_job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "started_at_utc", "completed_at_utc"],
      "properties": {
        "status": {
          "enum": ["PASS", "FAILED"]
        },
        "started_at_utc": {
          "$ref": "#/$defs/timestamp"
        },
        "completed_at_utc": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "completed_at_utc"],
      "properties": {
        "status": {
          "const": "PASS"
        },
        "completed_at_utc": {
          "$ref": "#/$defs/timestamp"
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "pull_request_number", "merge_commit_sha"],
      "properties": {
        "kind": {
          "enum": [
            "CONTROLLED_MOOMOOAU_PR",
            "EXACT_MAIN_NO_NEW_MOOMOOAU_DELIVERY"
          ]
        },
        "pull_request_number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "merge_commit_sha": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "CONTROLLED_MOOMOOAU_PR"
              }
            }
          },
          "then": {
            "properties": {
              "pull_request_number": {
                "type": "integer"
              },
              "merge_commit_sha": {
                "$ref": "#/$defs/sha"
              }
            }
          },
          "else": {
            "properties": {
              "pull_request_number": {
                "type": "null"
              },
              "merge_commit_sha": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "public_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_phase",
        "reason_code",
        "installation_token_failure_class",
        "exact_root_cause_claimed",
        "production_health_claimed",
        "final_acceptance_claimed"
      ],
      "properties": {
        "failure_phase": {
          "enum": [
            "UNDETERMINED_AGGREGATE_ONLY",
            "GITHUB_APP_TOKEN",
            "METADATA_VERIFICATION"
          ]
        },
        "reason_code": {
          "enum": [
            "PROTECTED_BETA_RUN_FAILED",
            "PROTECTED_BETA_GITHUB_APP_TOKEN_FAILED",
            "PROTECTED_BETA_METADATA_VERIFICATION_FAILED"
          ]
        },
        "installation_token_failure_class": {
          "enum": [
            "NOT_AVAILABLE_IN_HISTORICAL_AGGREGATE",
            "NOT_CLASSIFIED",
            "INSTALLATION_NOT_FOUND",
            "INSTALLATION_DISCOVERY_REJECTED",
            "INSTALLATION_ZERO",
            "INSTALLATION_SELECTION_REJECTED",
            "REQUEST_REJECTED",
            "RESPONSE_SCOPE_REJECTED",
            "UNCLASSIFIED"
          ]
        },
        "exact_root_cause_claimed": {
          "const": false
        },
        "production_health_claimed": {
          "const": false
        },
        "final_acceptance_claimed": {
          "const": false
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_ciphertext_commits",
        "raw_remote_recovery",
        "gmail_mutations",
        "m3_runs",
        "processed_writes",
        "timeline_writes",
        "scheduled_runs"
      ],
      "properties": {
        "raw_ciphertext_commits": {
          "enum": ["ZERO", "NONZERO_WITHIN_CONFIGURED_BUDGET"]
        },
        "raw_remote_recovery": {
          "enum": ["NOT_RUN", "ONE_HUNDRED_PERCENT"]
        },
        "gmail_mutations": {
          "const": 0
        },
        "m3_runs": {
          "const": 0
        },
        "processed_writes": {
          "const": 0
        },
        "timeline_writes": {
          "const": 0
        },
        "scheduled_runs": {
          "const": 0
        }
      }
    },
    "protected_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "delivery",
        "workflow_run_id",
        "workflow_run_url",
        "workflow_event",
        "workflow_attempt",
        "workflow_head_sha",
        "alpha_gate",
        "beta_raw_only",
        "identity_plaintext_cleanup",
        "public_failure",
        "effects"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 11
        },
        "delivery": {
          "$ref": "#/$defs/delivery"
        },
        "workflow_run_id": {
          "type": "integer",
          "minimum": 1
        },
        "workflow_run_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/LinzeColin/MetaDatabase/actions/runs/[0-9]+$"
        },
        "workflow_event": {
          "const": "workflow_dispatch"
        },
        "workflow_attempt": {
          "const": 1
        },
        "workflow_head_sha": {
          "$ref": "#/$defs/sha"
        },
        "alpha_gate": {
          "$ref": "#/$defs/passed_job"
        },
        "beta_raw_only": {
          "$ref": "#/$defs/beta_job"
        },
        "identity_plaintext_cleanup": {
          "$ref": "#/$defs/cleanup"
        },
        "public_failure": {
          "oneOf": [
            {
              "$ref": "#/$defs/public_failure"
            },
            {
              "type": "null"
            }
          ]
        },
        "effects": {
          "$ref": "#/$defs/effects"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "beta_raw_only": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "public_failure": {
                "type": "null"
              },
              "effects": {
                "properties": {
                  "raw_ciphertext_commits": {
                    "const": "NONZERO_WITHIN_CONFIGURED_BUDGET"
                  },
                  "raw_remote_recovery": {
                    "const": "ONE_HUNDRED_PERCENT"
                  }
                }
              }
            }
          },
          "else": {
            "properties": {
              "public_failure": {
                "$ref": "#/$defs/public_failure"
              },
              "effects": {
                "properties": {
                  "raw_ciphertext_commits": {
                    "const": "ZERO"
                  },
                  "raw_remote_recovery": {
                    "const": "NOT_RUN"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "rejected_dispatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_run_id",
        "workflow_run_url",
        "workflow_event",
        "workflow_attempt",
        "workflow_head_sha",
        "alpha_gate",
        "beta_raw_only",
        "reason_code",
        "pre_secret_rejection",
        "effects"
      ],
      "properties": {
        "workflow_run_id": {
          "const": 30046194781
        },
        "workflow_run_url": {
          "const": "https://github.com/LinzeColin/MetaDatabase/actions/runs/30046194781"
        },
        "workflow_event": {
          "const": "workflow_dispatch"
        },
        "workflow_attempt": {
          "const": 1
        },
        "workflow_head_sha": {
          "const": "5520b1642a74ff2063b3bec20af4f34bd8808532"
        },
        "alpha_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "started_at_utc", "completed_at_utc"],
          "properties": {
            "status": {
              "const": "FAILED"
            },
            "started_at_utc": {
              "const": "2026-07-23T21:26:43Z"
            },
            "completed_at_utc": {
              "const": "2026-07-23T21:26:46Z"
            }
          }
        },
        "beta_raw_only": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "completed_at_utc"],
          "properties": {
            "status": {
              "const": "SKIPPED"
            },
            "completed_at_utc": {
              "const": "2026-07-23T21:26:46Z"
            }
          }
        },
        "reason_code": {
          "const": "PRE_SECRET_CONTEXT_GATE_REJECTED"
        },
        "pre_secret_rejection": {
          "const": true
        },
        "effects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "protected_secret_reads",
            "raw_ciphertext_commits",
            "gmail_mutations",
            "m3_runs",
            "processed_writes",
            "timeline_writes",
            "scheduled_runs"
          ],
          "properties": {
            "protected_secret_reads": {
              "const": 0
            },
            "raw_ciphertext_commits": {
              "const": 0
            },
            "gmail_mutations": {
              "const": 0
            },
            "m3_runs": {
              "const": 0
            },
            "processed_writes": {
              "const": 0
            },
            "timeline_writes": {
              "const": 0
            },
            "scheduled_runs": {
              "const": 0
            }
          }
        }
      }
    }
  }
}
