{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PFI v0.2.5 Formula Registry",
  "type": "object",
  "required": ["schema", "registry_version", "base_currency", "fx_contract", "lifecycle", "formulas"],
  "properties": {
    "schema": {"const": "PFIV025FormulaRegistryV1"},
    "registry_version": {"const": "pfi-v0.2.5-formula-registry-v1"},
    "base_currency": {"const": "CNY"},
    "fx_contract": {
      "type": "object",
      "required": ["pair", "direction", "definition_zh", "rate_unit", "example_rate", "example_only", "production_default"],
      "properties": {
        "pair": {"const": "AUD/CNY"},
        "direction": {"const": "AUD_TO_CNY"},
        "definition_zh": {"const": "1 AUD = X CNY"},
        "rate_unit": {"const": "CNY/AUD"},
        "example_rate": {"const": "4.81"},
        "example_only": {"const": true},
        "production_default": {"type": "null"}
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["statuses", "active_versions_immutable", "replacement_rule_zh"],
      "properties": {
        "statuses": {"const": ["draft", "active", "deprecated", "superseded"]},
        "active_versions_immutable": {"const": true},
        "replacement_rule_zh": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "formulas": {
      "type": "array",
      "minItems": 20,
      "items": {"$ref": "#/$defs/formula"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "formula": {
      "type": "object",
      "required": ["formula_id", "version", "label_zh", "definition_zh", "inputs", "output", "outputs", "unit", "parameters", "boundaries_zh", "dependencies", "test_refs", "effective_from", "formula_hash", "validation_status", "lifecycle_status"],
      "properties": {
        "formula_id": {"pattern": "^FORM-PFI-[0-9]{3}$"},
        "version": {"type": "string", "minLength": 1},
        "label_zh": {"type": "string", "pattern": "[一-龥]"},
        "definition_zh": {"type": "string", "pattern": "[一-龥]"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "output": {"type": "string", "minLength": 1},
        "outputs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "unit": {"type": "string", "minLength": 1},
        "parameters": {"type": "array", "items": {"type": "string"}},
        "boundaries_zh": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "test_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "effective_from": {"type": "string", "format": "date"},
        "formula_hash": {"pattern": "^sha256:[0-9a-f]{64}$"},
        "validation_status": {"enum": ["validated", "partial", "blocked", "deprecated"]},
        "lifecycle_status": {"enum": ["draft", "active", "deprecated", "superseded"]},
        "historical_compatibility_zh": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
