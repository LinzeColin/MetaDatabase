{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfi.local/schemas/v025/account_role_assignment.schema.json",
  "title": "PFI v0.2.5 Account Role Assignment",
  "type": "object",
  "additionalProperties": false,
  "required": ["assignment_id", "account_ref", "source_id", "role", "effective_from", "effective_to", "status"],
  "properties": {
    "assignment_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
    "account_ref": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
    "source_id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
    "role": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"},
    "effective_from": {"type": "string", "format": "date"},
    "effective_to": {"type": ["string", "null"], "format": "date"},
    "status": {"enum": ["active", "ended", "pending_review"]}
  }
}
