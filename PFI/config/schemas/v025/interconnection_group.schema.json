{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pfi.local/schemas/v025/interconnection_group.schema.json",
  "title": "PFI v0.2.5 Interconnection Group",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "interconnection_group_id",
    "normalized_transaction_ids",
    "grouping_rule_id",
    "rule_version",
    "rule_hash",
    "reason_codes",
    "created_at"
  ],
  "properties": {
    "interconnection_group_id": {"type": "string", "pattern": "^interconnection_group_[0-9a-f]{20}$"},
    "normalized_transaction_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^normalized_transaction_[0-9a-f]{20}$"}
    },
    "grouping_rule_id": {"enum": ["explicit_link_reference_exact", "singleton_normalized_transaction"]},
    "rule_version": {"type": "string", "minLength": 1, "pattern": "^[^\\s]+$"},
    "rule_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"}
    },
    "link_reference_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
