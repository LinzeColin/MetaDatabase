{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PFI v0.2.5 Phase 2.3 Real-scale Read Parse Baseline",
  "type": "object",
  "required": [
    "schema",
    "version",
    "stage",
    "phase",
    "source_id",
    "status",
    "real_input_status",
    "isolation_mode",
    "record_count",
    "iterations",
    "elapsed_ms",
    "peak_python_alloc_bytes",
    "source_identity_before",
    "source_identity_after",
    "source_mutation_performed",
    "financial_fixture_fallback_used",
    "financial_values_emitted",
    "private_values_included"
  ],
  "properties": {
    "schema": {"const": "PFIV025Phase23PerformanceBaselineV1"},
    "version": {"const": "v0.2.5"},
    "stage": {"const": 2},
    "phase": {"const": "2.3"},
    "source_id": {"const": "SRC-TRANSACTIONS-ALIPAY"},
    "status": {"enum": ["pass", "blocked"]},
    "real_input_status": {"enum": ["ready", "source_missing"]},
    "isolation_mode": {"const": "immutable_git_object_snapshot"},
    "resolved_commit": {"type": ["string", "null"]},
    "tree_oid": {"type": ["string", "null"]},
    "transactions_blob_oid": {"type": ["string", "null"]},
    "parser": {"type": "string"},
    "input_bytes": {"type": ["integer", "null"], "minimum": 0},
    "manifest_record_count": {"type": ["integer", "null"], "minimum": 0},
    "record_count": {"type": ["integer", "null"], "minimum": 0},
    "field_count": {"type": ["integer", "null"], "minimum": 0},
    "record_count_matches_manifest": {"type": "boolean"},
    "iterations": {"type": "integer", "minimum": 1, "maximum": 10},
    "elapsed_ms": {"type": ["object", "null"]},
    "peak_python_alloc_bytes": {"type": ["object", "null"]},
    "source_identity_before": {"type": "object"},
    "source_identity_after": {"type": "object"},
    "source_mutation_performed": {"const": false},
    "financial_fixture_fallback_used": {"const": false},
    "financial_values_emitted": {"const": 0},
    "raw_rows_emitted": {"const": 0},
    "private_values_included": {"const": false},
    "finder_used": {"const": false}
  },
  "additionalProperties": false
}
