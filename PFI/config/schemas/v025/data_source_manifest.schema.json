{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PFI Data Source Manifest",
  "type": "object",
  "required": [
    "source_id",
    "source_type",
    "capabilities",
    "status",
    "record_count",
    "coverage",
    "as_of",
    "content_hash"
  ],
  "properties": {
    "source_id": {"type": "string"},
    "source_type": {"type": "string"},
    "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "path_alias": {"type": ["string", "null"]},
    "parser_version": {"type": ["string", "null"]},
    "status": {
      "enum": [
        "ready",
        "partial",
        "not_loaded",
        "source_missing",
        "path_error",
        "parse_failed",
        "outdated",
        "permission_denied",
        "blocked"
      ]
    },
    "record_count": {"type": ["integer", "null"], "minimum": 0},
    "coverage": {
      "type": "object",
      "properties": {
        "start": {"type": ["string", "null"]},
        "end": {"type": ["string", "null"]}
      }
    },
    "as_of": {"type": ["string", "null"]},
    "content_hash": {"type": ["string", "null"]},
    "blocking_reason_zh": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
