{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PFI v0.2.5 Point-in-Time Valuation Snapshot",
  "type": "object",
  "required": [
    "schema",
    "status",
    "holding_snapshot_id",
    "price_snapshot_id",
    "fx_snapshot_id",
    "source_ids",
    "original_currency",
    "quantity",
    "price",
    "market_value_original",
    "cost_basis_original",
    "fx_rate",
    "market_value_cny",
    "cost_basis_cny",
    "unrealized_pnl_cny",
    "cost_basis_method",
    "quantity_as_of",
    "price_as_of",
    "fx_effective_at",
    "valuation_as_of",
    "holding_source_hash",
    "price_source_hash",
    "fx_source_hash",
    "cost_formula_id",
    "cost_formula_hash",
    "valuation_formula_id",
    "valuation_formula_hash",
    "parameter_hash",
    "calculation_state",
    "rounding_applied"
  ],
  "$defs": {
    "decimalString": {"type": "string", "pattern": "^-?[0-9]+(?:\\.[0-9]+)?$"},
    "sha256OrNull": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "properties": {
    "schema": {"const": "PFIV025ValuationSnapshotV1"},
    "status": {"const": "ready"},
    "holding_snapshot_id": {"type": "string", "minLength": 1},
    "price_snapshot_id": {"type": "string", "minLength": 1},
    "fx_snapshot_id": {"type": ["string", "null"]},
    "source_ids": {"type": "array", "items": {"type": "string"}, "minItems": 2, "uniqueItems": true},
    "original_currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "quantity": {"$ref": "#/$defs/decimalString"},
    "price": {"$ref": "#/$defs/decimalString"},
    "market_value_original": {"$ref": "#/$defs/decimalString"},
    "cost_basis_original": {"$ref": "#/$defs/decimalString"},
    "fx_rate": {"$ref": "#/$defs/decimalString"},
    "market_value_cny": {"type": "string", "pattern": "^-?[0-9]+(?:\\.[0-9]+)?$"},
    "cost_basis_cny": {"$ref": "#/$defs/decimalString"},
    "unrealized_pnl_cny": {"$ref": "#/$defs/decimalString"},
    "cost_basis_method": {
      "enum": ["source_reported", "specific_identification", "fifo", "weighted_average"]
    },
    "quantity_as_of": {"type": "string", "format": "date-time"},
    "price_as_of": {"type": "string", "format": "date-time"},
    "fx_effective_at": {"type": ["string", "null"], "format": "date-time"},
    "valuation_as_of": {"type": "string", "format": "date-time"},
    "holding_source_hash": {"$ref": "#/$defs/sha256OrNull"},
    "price_source_hash": {"$ref": "#/$defs/sha256OrNull"},
    "fx_source_hash": {"$ref": "#/$defs/sha256OrNull"},
    "cost_formula_id": {"const": "FORM-PFI-009"},
    "cost_formula_hash": {"$ref": "#/$defs/sha256OrNull"},
    "valuation_formula_id": {"const": "FORM-PFI-010"},
    "valuation_formula_hash": {"$ref": "#/$defs/sha256OrNull"},
    "parameter_hash": {"$ref": "#/$defs/sha256OrNull"},
    "calculation_state": {"const": "calculated_contract_test_only"},
    "rounding_applied": {"const": false}
  },
  "additionalProperties": false
}
