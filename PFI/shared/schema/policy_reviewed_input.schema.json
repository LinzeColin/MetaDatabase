{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/PFI/shared/schema/policy_reviewed_input.schema.json",
  "title": "PFI Policy Reviewed Input",
  "description": "Public contract for local reviewed Policy Intelligence input. Real inputs should stay under data/private/policy and must not be committed.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["published_date", "title", "source_name", "source_type", "review_status"],
    "additionalProperties": true,
    "properties": {
      "policy_id": {"type": "string"},
      "published_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "title": {"type": "string", "minLength": 1},
      "jurisdiction": {"type": "string"},
      "policy_level": {"type": "string", "enum": ["National", "State", "City", "Agency", "Industry", "Company", "Unknown"]},
      "source_name": {"type": "string", "minLength": 1},
      "source_type": {"type": "string", "enum": ["Official", "Regulator", "Government", "Exchange", "Research", "News", "Manual"]},
      "source_url": {"type": "string"},
      "evidence_path": {"type": "string"},
      "review_status": {"type": "string", "enum": ["PendingReview", "Reviewed", "Rejected"]},
      "opportunity_type": {
        "type": "string",
        "enum": ["Subsidy", "RegulatoryChange", "Procurement", "Tax", "IndustrySupport", "RiskWarning", "Compliance", "Other"]
      },
      "sectors": {"type": ["string", "array"]},
      "affected_entities": {"type": ["string", "array"]},
      "impact_summary": {"type": "string"},
      "required_action": {"type": "string"},
      "authority_score": {"type": "number", "minimum": 0, "maximum": 100},
      "relevance_score": {"type": "number", "minimum": 0, "maximum": 100},
      "urgency_score": {"type": "number", "minimum": 0, "maximum": 100},
      "feasibility_score": {"type": "number", "minimum": 0, "maximum": 100},
      "notes": {"type": "string"}
    }
  }
}
