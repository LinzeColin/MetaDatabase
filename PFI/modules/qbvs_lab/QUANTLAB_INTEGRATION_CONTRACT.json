  "data_cache_contract": {
    "cache_index": "data_cache/cache_index.csv",
    "cache_file_format": "standard OHLCV CSV",
    "required_columns": [
      "datetime",
      "symbol",
      "market",
      "open",
      "high",
      "low",
      "close",
      "volume"
    ],
    "metadata_format": "<market>/<symbol>.metadata.json"
  },
  "real_tradable_data_contract": {
    "principle": "do not synthesize tradable-source data when source is unavailable",
    "moomoo_opend": {
      "probe_command": "probe-moomoo-opend",
      "history_cache_command": "cache-moomoo-history",
      "default_host": "127.0.0.1",
      "default_port": 11111,
      "readiness_requires": [
        "OpenD socket reachable",
        "futu or moomoo SDK importable"
      ],
      "not_ready_exit_code": 2
    },
    "alipay_fund": {
      "cache_command": "cache-alipay-fund-nav",
      "source_format": "user exported fund NAV CSV",
      "required_columns": [
        "date",
        "nav"
      ],
      "market": "ALIPAY_FUND",
      "asset_class": "FUND",
      "tradability": "CONFIRMED_SOURCE_NEEDS_ORDER_RULE_CHECK"
    },
    "universe_template_command": "create-tradable-universe-template",
    "seed_universe": {
      "schema_version": "qbvs-tradable-universe-seed-v1",
      "create_command": "create-seed-universe",
      "verify_command": "verify-seed-universe",
      "cache_plan_command": "build-seed-cache-plan",
      "yahoo_universe_command": "build-seed-yahoo-universe",
      "yahoo_cache_plan_command": "build-seed-yahoo-cache-plan",
      "minimum_symbols": 200,
      "seed_is_candidate_pool_not_confirmed_tradable_pool": true,
      "starts_background_processes": false,
      "requires_before_live_cache": [
        "Moomoo/OpenD ready",
        "futu or moomoo SDK importable",
        "account/data permissions confirmed",
        "data quality gate passed"
      ]
    },
    "yahoo_public_fallback": {
      "purpose": "public historical data fallback when Moomoo/OpenD is not ready",
      "cache_command": "cache-yahoo",
      "universe_command": "build-seed-yahoo-universe",
      "cache_plan_command": "build-seed-yahoo-cache-plan",
      "sample_universe_command": "sample-universe",
      "boundary": "not proof of account tradability; use for read-only historical validation and pipeline smoke tests",
      "starts_background_processes": false,
      "writes_quantlab_database": false,
      "writes_quantlab_source": false
    }
  },
  "alipay_fund_execution_contract": {
    "purpose": "validate behavior strategies under simplified Alipay fund subscription and redemption mechanics",
    "cli_commands": [
      "create-fund-rule-template",
      "validate-fund-csv"
    ],
    "engine": "alipay_fund_rules",
    "inputs": [
      "standard OHLCV CSV or cached Alipay NAV CSV",
      "BehaviorStrategySpec generated signals",
      "fund trading rule JSON"
    ],
    "rule_fields": [
      "initial_cash",
      "subscription_fee_rate",
      "redemption_fee_rate_short",
      "redemption_fee_rate_long",
      "short_holding_days",
      "min_holding_days",
      "buy_confirmation_days",
      "sell_cash_delay_days",
      "annualization"
    ],
    "outputs": [
      "fund_validation_results.csv",
      "fund_strategy_summary.csv",
      "fund_trading_rule.json",
      "Alipay_Fund_Strategy_Validation_Report.pdf"
    ],
    "boundary": "simplified execution model; exact fund-specific fee tiers, holidays, purchase limits, redemption restrictions, and settlement calendars require per-fund rule override"
  },
  "data_quality_contract": {
    "quality_score_range": "0-100",
    "recommended_min_quality_score": 70,
    "quality_grades": ["A", "B", "C", "D", "F"],
    "metadata_fields": [
      "asset_class",
      "tradability",
      "currency",
      "timezone",
      "quality_score",
      "quality_grade",
      "quality_warnings",
      "gap_ratio",
      "max_abs_daily_return"
    ],
    "run_manifest_quality_gate": {
      "cli_flags": [
        "--min-quality-score",
        "--skip-low-quality"
      ],
      "skip_status": "skipped_quality",
      "missing_quality_score_behavior": "do_not_skip_but_mark_as_missing_quality"
    }
  },
  "task_planning_contract": {
    "split_manifest_output": "manifest_part_index.csv",
    "budget_estimate_output": "budget_estimate.json",
    "budget_inputs": [
      "tasks",
      "seconds_per_task",
      "workers",
      "million_test_multiplier"
    ],
    "stratified_sample_command": "sample-manifest",
    "stratified_sample_default_group_cols": [
      "symbol",
      "strategy_id"
    ],
    "stratified_sample_purpose": "create representative short-run subsets across symbols and behavior strategies before long campaign execution"
  },
  "long_run_campaign_contract": {
    "schema_version": "qbvs-long-run-campaign-v1",
    "purpose": "turn a manifest into reviewable long-run shards, budget, commands, and status files",
    "cli_commands": [
      "build-campaign",
      "verify-campaign",
      "promote-candidates"
    ],
    "starts_background_processes": false,
    "writes_quantlab_database": false,
    "writes_quantlab_source": false,
    "execution_mode": "manual_or_external_scheduler_runs_commands",
    "outputs": [
      "campaign_plan.json",
      "campaign_manifest.csv",
      "manifest_parts/campaign_part_index.csv",
      "campaign_status.csv",
      "run_commands.sh",
      "campaign_verification.json",
      "promotion_candidates.csv"
    ],
    "candidate_gate_default_floor": {
      "total_return_gap_vs_buy_hold_min": -0.08,
      "annualized_return_gap_vs_buy_hold_min": -0.03,
      "drawdown_improvement_min": -0.005,
      "requires_quantlab_exact_rerun": true,
      "requires_user_approval_before_strategy_library_write": true
    }
  },
  "warehouse_contract": {
    "database": "warehouse/qbvs_results.sqlite",
    "owner": "quant_behavior_validation_system",
    "not_quantlab_database": true,
    "tables": [
      "runs",
      "validation_results",
      "strategy_summaries",
      "strategy_market_summary"
    ],
    "cli_commands": [
      "warehouse-init",
      "warehouse-import-runs",
      "warehouse-stats",
      "warehouse-export"
    ]
  },
  "fast_screening_contract": {
    "purpose": "candidate narrowing before exact validation",
    "engine": "vectorized target-weight approximation",
    "uses_same_strategy_signals": true,
    "not_final_approval_engine": true,
    "required_exact_rerun_for_finalists": true,
    "outputs": [
      "fast_validation_results.csv",
      "fast_strategy_summary.csv",
      "Behavior_Strategy_Fast_Screen_Report.pdf",
      "fast_exact_comparison.csv",
      "fast_exact_summary.csv",
      "Behavior_Strategy_Fast_Exact_Benchmark_Report.pdf"
    ],
    "cli_commands": [
      "fast-screen-csv",
      "fast-benchmark-csv"
    ]
  },
  "quantlab_evidence_bundle_contract": {
    "schema_version": "qbvs-quantlab-evidence-bundle-v1",
    "purpose": "export one QBVS run into a QuantLab-readable external evidence package",
    "ingestion_mode": "external_evidence_only",
    "writes_quantlab_database": false,
    "writes_quantlab_source": false,
    "cli_commands": [
      "export-quantlab-bundle",
      "verify-quantlab-bundle"
    ],
    "outputs": [
      "quantlab_bundle_manifest.json",
      "quantlab_ingestion_payload.json",
      "quantlab_candidate_strategies.csv",
      "quantlab_bundle_verification.json",
      "QuantLab_Integration_Bundle_Report.pdf"
    ],
    "candidate_required_columns": [
      "strategy_id",
      "approval_state",
      "requires_exact_validation",
      "pass_rate",
      "avg_total_gap",
      "avg_annualized_gap"
    ],
    "fast_screening_rule": "fast_screen candidates must be rerun by exact validation before strategy approval"
  },
  "quantlab_readonly_adapter_pack_contract": {
    "schema_version": "qbvs-quantlab-readonly-adapter-pack-v1",
    "purpose": "provide QuantLab-side reference code for reading QBVS bundles, campaigns, and promotion candidates as review-only evidence",
    "cli_commands": [
      "build-quantlab-adapter-pack",
      "verify-quantlab-adapter-pack"
    ],
    "writes_quantlab_database": false,
    "modifies_quantlab_source": false,
    "recommended_quantlab_status": "ReviewOnly",
    "recommended_quantlab_table": "independent_validation_runs",
    "outputs": [
      "adapter_pack_manifest.json",
      "quantlab_qbvs_readonly_adapter.py",
      "test_quantlab_qbvs_readonly_adapter.py",
      "README.md",
      "sample_ingestion_request.json",
      "adapter_pack_verification.json"
    ],
    "required_guards": [
      "external_evidence_only",
      "requires_exact_rerun",
      "requires_user_approval_before_database_write"
    ]
  },
  "resumable_task_contract": {
    "manifest_file": "task_manifest.csv",
    "task_cache_dir": "task_results",
    "task_cache_key": "task_id",
    "resume_behavior": "skip existing task_results/<task_id>.json by default",
    "aggregate_outputs": [
      "task_status.csv",
      "validation_results.csv",
      "strategy_summary.csv",
      "Behavior_Strategy_Task_Run_Report.pdf"
    ]
  },
  "user_acceptance_floor": {
    "total_return_gap_vs_buy_hold_min": -0.08,
    "annualized_return_gap_vs_buy_hold_min": -0.03,
    "drawdown_improvement_min": -0.005
  },
  "recommended_default_strategy_family": {
    "base_weight": 0.99,
    "dip_trigger": "boll_lower",
    "sell_trigger": "none",
    "trend_rule": "strong_trend_full",
    "risk_rule": "none"
  }
}
