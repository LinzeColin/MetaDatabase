COMMAND: for pid in $(lsof -nP -iTCP:8501-8510 -sTCP:LISTEN -t 2>/dev/null | sort -u); do
  printf 'PID=%s\n' "$pid"
  ps -p "$pid" -o pid=,ppid=,command=
  lsof -a -p "$pid" -d cwd -Fn
  port=$(lsof -nP -a -p "$pid" -iTCP -sTCP:LISTEN -Fn 2>/dev/null \
    | sed -nE 's/^n.*:([0-9]+)$/\1/p' | head -1)
  if [ -n "$port" ]; then
    curl -sS --max-time 2 -o /dev/null -w '%{http_code}\n' \
      "http://127.0.0.1:$port/_stcore/health"
  fi
done
EXIT_CODE: 0
SUMMARY: Both PID cwd values resolved exactly to /Users/linzezhang/Documents/Codex/main_worktree/CodexProject/pfi/PFI; health returned HTTP 200 on ports 8501 and 8502. No service was started, stopped, or refreshed.

