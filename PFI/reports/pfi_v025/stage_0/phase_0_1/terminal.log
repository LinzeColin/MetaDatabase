COMMAND: (
  db_count_before=$(find "$HOME/.pfi" -type f \( -iname '*.db' -o -iname '*.sqlite' -o -iname '*.sqlite3' \) 2>/dev/null | wc -l | tr -d ' ')
  printf 'candidate_count_before=%s\n' "$db_count_before"
  if [ "$db_count_before" -eq 0 ]; then
    printf 'local_pfi_sqlite=not_found\n'
    exit 0
  fi
  if [ "$db_count_before" -ne 1 ]; then
    printf 'local_pfi_sqlite=ambiguous|count=%s\n' "$db_count_before"
    exit 1
  fi
  db_path=$(find "$HOME/.pfi" -type f \( -iname '*.db' -o -iname '*.sqlite' -o -iname '*.sqlite3' \) -print -quit 2>/dev/null)
  before_bytes=$(stat -f '%z' "$db_path")
  before_mtime=$(stat -f '%m' "$db_path")
  before_mode=$(stat -f '%Sp' "$db_path")
  before_hash=$(openssl dgst -sha256 -r "$db_path" | awk '{print $1}')
  printf 'before|redacted_id=local_sqlite_candidate_01|bytes=%s|mtime_epoch=%s|mode=%s|sha256=%s\n' "$before_bytes" "$before_mtime" "$before_mode" "$before_hash"
  sqlite_output=$(sqlite3 "file:$db_path?mode=ro&immutable=1" "PRAGMA query_only=ON; PRAGMA quick_check; SELECT 'table_count=' || count(*) FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%';")
  sqlite_exit=$?
  printf '%s\n' "$sqlite_output"
  db_count_after=$(find "$HOME/.pfi" -type f \( -iname '*.db' -o -iname '*.sqlite' -o -iname '*.sqlite3' \) 2>/dev/null | wc -l | tr -d ' ')
  printf 'candidate_count_after=%s\n' "$db_count_after"
  if [ "$db_count_after" -ne 1 ]; then
    printf 'local_pfi_sqlite=changed_or_ambiguous|count=%s\n' "$db_count_after"
    exit 1
  fi
  db_path_after=$(find "$HOME/.pfi" -type f \( -iname '*.db' -o -iname '*.sqlite' -o -iname '*.sqlite3' \) -print -quit 2>/dev/null)
  after_bytes=$(stat -f '%z' "$db_path_after")
  after_mtime=$(stat -f '%m' "$db_path_after")
  after_mode=$(stat -f '%Sp' "$db_path_after")
  after_hash=$(openssl dgst -sha256 -r "$db_path_after" | awk '{print $1}')
  printf 'after|redacted_id=local_sqlite_candidate_01|bytes=%s|mtime_epoch=%s|mode=%s|sha256=%s\n' "$after_bytes" "$after_mtime" "$after_mode" "$after_hash"
  unchanged=false
  if [ "$db_count_before" = "$db_count_after" ] && [ "$db_path" = "$db_path_after" ] && [ "$before_bytes" = "$after_bytes" ] && [ "$before_mtime" = "$after_mtime" ] && [ "$before_mode" = "$after_mode" ] && [ "$before_hash" = "$after_hash" ]; then
    unchanged=true
  fi
  printf 'unchanged=%s\n' "$unchanged"
  [ "$sqlite_exit" -eq 0 ] && [ "$(printf '%s\n' "$sqlite_output" | sed -n '1p')" = 'ok' ] && [ "$(printf '%s\n' "$sqlite_output" | sed -n '2p')" = 'table_count=9' ] && [ "$unchanged" = true ]
)
