# Copy to config/odds_providers.local.env on the local machine only.
# Never commit the real file or a real API key.

THE_ODDS_API_KEY=replace_with_rotated_key
TAB_FIFA_PROVIDER_SCOPE=matches
TAB_FIFA_THE_ODDS_API_SPORTS=soccer_fifa_world_cup
TAB_FIFA_THE_ODDS_API_SPORT_DISCOVERY=1

# Matches-first, credit-aware default:
# h2h = Result / 1X2, totals = Total Score O/U, spreads = handicap context.
TAB_FIFA_THE_ODDS_API_MATCH_MARKETS=h2h,totals,spreads

# Optional only if the provider account and sport support these market keys.
# Unsupported markets can make the request fail or waste credits, so keep empty until verified.
TAB_FIFA_THE_ODDS_API_EXTRA_MATCH_MARKETS=

# Credit-aware event-level alternate market probing. Keep 0 for normal automation.
# Recommended explicit probe path covers value-support markets already seen in TAB event-market samples.
# Team Total stays on OpticOdds/TAB manual fallback until provider support is proven, to avoid wasting monthly credits.
TAB_FIFA_THE_ODDS_API_EVENT_MARKET_PROBE_LIMIT=0
TAB_FIFA_THE_ODDS_API_EVENT_ODDS_LIMIT=3
TAB_FIFA_THE_ODDS_API_EVENT_ODDS_MARKETS=alternate_totals,alternate_spreads,btts,double_chance,draw_no_bet

# Region-specific TAB boards such as Australia Markets are ignored by default for provider refresh.
TAB_FIFA_IGNORE_REGION_MARKETS=1

# Optional secondary provider.
OPTICODDS_API_KEY=replace_with_opticodds_key_if_available
TAB_FIFA_OPTICODDS_ENDPOINT=/fixtures/odds
TAB_FIFA_OPTICODDS_QUERY="sport=soccer&sportsbook=TAB"
