{
  "protocol_version": "qbvs-quantlab-handshake-v1",
  "systems": {
    "source": "quant_behavior_validation_system",
    "target": "quantlab"
  },
  "boundary": {
    "qbvs_imports_quantlab": false,
    "qbvs_writes_quantlab_source": false,
    "qbvs_writes_quantlab_database": false,
    "quantlab_reads_qbvs_artifacts": true
  },
  "request_file": "handoff/qbvs_handshake_request.json",
  "ack_template_file": "handoff/quantlab_handshake_ack_template.json",
  "ack_file": "handoff/quantlab_handshake_ack.json",
  "ack_required_fields": [
    "protocol_version",
    "message_type",
    "source_system",
    "target_system",
    "accepted",
    "consume_mode",
    "quantlab_entrypoint"
  ],
  "same_instruction_behavior": {
    "when_user_sends_same_instruction_to_quantlab": [
      "read QBVS HANDOFF.md",
      "read QUANTLAB_INTEGRATION_CONTRACT.json",
      "read handoff/qbvs_handshake_request.json",
      "select or state QuantLab's read-only entrypoint for QBVS artifacts",
      "write handoff/quantlab_handshake_ack.json from the template",
      "do not write QuantLab database or approved strategy library without explicit user approval"
    ],
    "when_qbvs_receives_quantlab_ack": [
      "run qbvs.cli verify-handshake against handoff/quantlab_handshake_ack.json",
      "rerun goal-readiness audit with the real ack",
      "treat interop as complete only when valid=true"
    ]
  },
  "accepted_artifact_patterns": [
    "QUANTLAB_INTEGRATION_CONTRACT.json",
    "HANDOFF.md",
    "HANDSHAKE_PROTOCOL.json",
    "handoff/qbvs_handshake_request.json",
    "handoff/quantlab_handshake_ack_template.json",
    "handoff/quantlab_readonly_adapter_pack/*",
    "handoff/**/quantlab_bundle_manifest.json",
    "handoff/**/quantlab_ingestion_payload.json",
    "handoff/**/quantlab_candidate_strategies.csv",
    "runs/**/strategy_summary.csv",
    "runs/**/validation_results.csv",
    "runs/**/task_status.csv",
    "runs/**/Behavior_Strategy_*.pdf",
    "data_cache/**/cache_index.csv"
  ],
  "latest_recommended_bundles": [
    "handoff/quantlab_bundle_yahoo_public_top20_finalist_200symbols_5windows",
    "handoff/quantlab_bundle_moomoo_batch10_top20_finalist_3windows",
    "handoff/quantlab_bundle_moomoo_batch30_top20_finalist_3windows",
    "handoff/quantlab_bundle_moomoo_batch80_top20_finalist_3windows",
    "handoff/quantlab_bundle_moomoo_batch100_top20_finalist_3windows"
  ],
  "success_condition": {
    "ack.protocol_version": "qbvs-quantlab-handshake-v1",
    "ack.message_type": "handshake_ack",
    "ack.source_system": "quantlab",
    "ack.target_system": "quant_behavior_validation_system",
    "ack.accepted": true,
    "ack.quantlab_entrypoint": "non-empty"
  }
}
