{
  "manifest_version": 3,
  "name": "x2n Development Side Panel",
  "version": "0.0.0.1",
  "description": "Personal content knowledge governance with explicit current-page capture.",
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "sidePanel"
  ],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open x2n Side Panel"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
