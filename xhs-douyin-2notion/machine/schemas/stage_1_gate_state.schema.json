{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/MetaDatabase/xhs-douyin-2notion/machine/schemas/stage_1_gate_state.schema.json",
  "title": "x2n Stage 1 Gate State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "stage",
    "review_id",
    "run_id",
    "review_base_commit",
    "review_sync_target",
    "review_status",
    "automated_reacceptance",
    "gate_id",
    "gate_status",
    "gate_decision",
    "pass_conditions",
    "stop_conditions",
    "blocking_followups",
    "stage_2_authorized",
    "remote_upload",
    "remote_ci_execution",
    "next_task",
    "product_scope",
    "real_account_execution",
    "platform_calls",
    "notion_calls",
    "model_calls",
    "media_processing"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "project": {"const": "x2n"},
    "stage": {"const": "STG.X2N.1"},
    "review_id": {"const": "STG.X2N.1.REVIEW"},
    "run_id": {"const": "RUN-X2N-S01-REVIEW"},
    "review_base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "review_sync_target": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "review_status": {"const": "complete"},
    "automated_reacceptance": {"const": "pass"},
    "gate_id": {"const": "G1"},
    "gate_status": {"enum": ["pass", "fail"]},
    "gate_decision": {"enum": ["pass", "fail_closed"]},
    "pass_conditions": {
      "type": "object",
      "minProperties": 4,
      "additionalProperties": {"enum": ["pass", "fail", "unknown"]}
    },
    "stop_conditions": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {"enum": ["inactive", "active", "unknown"]}
    },
    "blocking_followups": {"type": "array", "maxItems": 0},
    "stage_2_authorized": {"type": "boolean"},
    "remote_upload": {"enum": ["authorized_after_g1_pass", "forbidden_until_g1_pass"]},
    "remote_ci_execution": {"enum": ["pending_post_g1_upload", "pass", "fail"]},
    "next_task": {"const": "TSK.x2n.skeleton.001"},
    "product_scope": {"const": "stage_1_foundation_only"},
    "real_account_execution": {"const": "not_run"},
    "platform_calls": {"const": "not_run"},
    "notion_calls": {"const": "not_run"},
    "model_calls": {"const": "not_run"},
    "media_processing": {"const": "not_run"}
  }
}
