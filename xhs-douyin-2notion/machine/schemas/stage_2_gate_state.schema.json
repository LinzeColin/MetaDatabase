{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/MetaDatabase/xhs-douyin-2notion/machine/schemas/stage_2_gate_state.schema.json",
  "title": "x2n Stage 2 Gate State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "stage",
    "review_id",
    "run_id",
    "stage_base_commit",
    "review_base_commit",
    "review_sync_target",
    "review_status",
    "automated_reacceptance",
    "gate_id",
    "gate_status",
    "gate_decision",
    "assurance_scope",
    "pass_conditions",
    "stop_conditions",
    "blocking_followups",
    "stage_2_remote_upload_authorized",
    "stage_3_authorized",
    "remote_upload",
    "remote_ci_execution",
    "next_action",
    "formal_verifier_release_candidate",
    "public_release_authorized",
    "product_scope",
    "real_account_execution",
    "platform_calls",
    "notion_calls",
    "model_calls",
    "media_processing"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "project": {"const": "x2n"},
    "stage": {"const": "STG.X2N.2"},
    "review_id": {"const": "STG.X2N.2.REVIEW"},
    "run_id": {"const": "RUN-X2N-S02-REVIEW"},
    "stage_base_commit": {"pattern": "^[0-9a-f]{40}$"},
    "review_base_commit": {"pattern": "^[0-9a-f]{40}$"},
    "review_sync_target": {"pattern": "^[0-9a-f]{40}$"},
    "review_status": {"const": "complete"},
    "automated_reacceptance": {"const": "pass"},
    "gate_id": {"const": "G2"},
    "gate_status": {"const": "pass"},
    "gate_decision": {"const": "pass"},
    "assurance_scope": {"const": "project_native_local_developer_gate"},
    "pass_conditions": {"type": "object"},
    "stop_conditions": {"type": "object"},
    "blocking_followups": {"type": "array", "maxItems": 0},
    "stage_2_remote_upload_authorized": {"const": true},
    "stage_3_authorized": {"const": false},
    "remote_upload": {"const": "authorized_after_g2_pass"},
    "remote_ci_execution": {"const": "pending_post_g2_upload"},
    "next_action": {"const": "stage_2_whole_stage_remote_upload"},
    "formal_verifier_release_candidate": {"const": "blocked_requirement_gap_missing_canonical_manifest"},
    "public_release_authorized": {"const": false},
    "product_scope": {"const": "stage_2_walking_skeleton_ci_synthetic_and_notion_mock_only"},
    "real_account_execution": {"const": "not_run"},
    "platform_calls": {"const": "not_run"},
    "notion_calls": {"const": "mock_only_real_api_not_run"},
    "model_calls": {"const": "not_run"},
    "media_processing": {"const": "not_run"}
  }
}
