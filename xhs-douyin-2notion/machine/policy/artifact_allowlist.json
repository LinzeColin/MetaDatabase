{
  "schema_version": "1.0",
  "policy_id": "ARTIFACT.X2N.001",
  "allowed_classes": [
    "proprietary_source_code",
    "schemas_and_contracts",
    "synthetic_registered_fixtures",
    "product_design_and_governance",
    "redacted_compact_evidence",
    "dependency_and_license_manifests"
  ],
  "denied_classes": [
    "credentials_or_session_state",
    "browser_profiles",
    "runtime_databases",
    "raw_media",
    "private_content_or_model_io",
    "platform_media_cdn_urls",
    "local_absolute_paths",
    "unredacted_logs_or_diagnostics"
  ],
  "enforcement": [
    ".gitignore",
    "scripts/verify_phase_0_1.py",
    "scripts/verify_phase_0_2.py",
    "future_shared_governance_ci"
  ]
}
