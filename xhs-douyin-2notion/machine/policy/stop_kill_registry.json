    {"id": "SK-X2N-016", "trigger": "notion_outage_or_limit", "action": ["stop_sink_only"]},
    {"id": "SK-X2N-017", "trigger": "ai_top_level_taxonomy_mutation", "action": ["stop_classifier"]},
    {"id": "SK-X2N-018", "trigger": "workspace_scope_escape", "action": ["stop"]},
    {"id": "SK-X2N-019", "trigger": "premature_remote_upload", "action": ["stop"]},
    {"id": "SK-X2N-020", "trigger": "unauthorized_external_execution", "action": ["incident", "kill_global"]}
