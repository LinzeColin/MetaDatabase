    {"id": "SK-X2N-002", "trigger": "rate_limit_or_abnormal_access", "action": ["stop", "kill_platform"]},
    {"id": "SK-X2N-003", "trigger": "auth_expired_or_scope_missing", "action": ["stop", "kill_platform"]},
    {"id": "SK-X2N-004", "trigger": "dom_api_schema_drift", "action": ["stop", "kill_platform"]},
    {"id": "SK-X2N-005", "trigger": "policy_unknown", "action": ["stop", "kill_platform"]},
    {"id": "SK-X2N-006", "trigger": "license_or_provenance_unknown", "action": ["stop", "kill_global"]},
    {"id": "SK-X2N-007", "trigger": "bypass_or_automation_required", "action": ["stop", "kill_platform"]},
    {"id": "SK-X2N-008", "trigger": "credential_or_private_content_leak", "action": ["incident", "kill_global"]},
    {"id": "SK-X2N-009", "trigger": "cdn_url_or_raw_media_persisted", "action": ["incident", "kill_global"]},
    {"id": "SK-X2N-010", "trigger": "ssrf_or_private_network", "action": ["incident", "kill_global"]},
