{
  "schema_version": "1.0",
  "source": "docs/security/STOP_KILL_INCIDENT_REGISTER.md",
  "actions": ["stop", "stop_sink_only", "stop_classifier", "kill_platform", "kill_global", "incident"],
  "rules": [
