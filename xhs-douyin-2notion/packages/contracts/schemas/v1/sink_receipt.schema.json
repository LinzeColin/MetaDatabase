{
  "$defs": {
    "SinkKind": {
      "enum": [
        "markdown",
        "notion"
      ],
      "title": "SinkKind",
      "type": "string"
    },
    "SinkReceiptStatus": {
      "enum": [
        "delivered",
        "verified",
        "failed"
      ],
      "title": "SinkReceiptStatus",
      "type": "string"
    }
  },
  "$id": "urn:x2n:contract:1.0:sink_receipt",
  "additionalProperties": false,
  "properties": {
    "content_key": {
      "maxLength": 768,
      "minLength": 3,
      "title": "Content Key",
      "type": "string"
    },
    "delivered_at": {
      "format": "date-time",
      "title": "Delivered At",
      "type": "string"
    },
    "desired_projection_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Desired Projection Hash",
      "type": "string"
    },
    "external_ref_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "External Ref Hash"
    },
    "output_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Output Hash",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
      "title": "Receipt Id",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sink": {
      "$ref": "#/$defs/SinkKind"
    },
    "sink_key": {
      "maxLength": 768,
      "minLength": 3,
      "title": "Sink Key",
      "type": "string"
    },
    "sink_object_ref": {
      "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
      "title": "Sink Object Ref",
      "type": "string"
    },
    "sink_schema_version": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Sink Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SinkReceiptStatus"
    }
  },
  "required": [
    "schema_version",
    "receipt_id",
    "sink_key",
    "sink",
    "content_key",
    "sink_schema_version",
    "desired_projection_hash",
    "output_hash",
    "sink_object_ref",
    "status",
    "delivered_at",
    "run_id"
  ],
  "title": "SinkReceipt",
  "type": "object",
  "x-x2n-compatibility": "exact_match_fail_closed",
  "x-x2n-contract-version": "1.0"
}
