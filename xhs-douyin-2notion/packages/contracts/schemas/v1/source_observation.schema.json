{
  "$defs": {
    "CanonicalField": {
      "enum": [
        "platform_content_id",
        "canonical_source_url",
        "content_type",
        "title",
        "description",
        "author_name",
        "author_platform_id",
        "published_at"
      ],
      "title": "CanonicalField",
      "type": "string"
    },
    "ErrorCode": {
      "enum": [
        "X2N_INVALID_SCHEMA_VERSION",
        "X2N_UNKNOWN_FIELD",
        "X2N_INVALID_INPUT",
        "X2N_NATIVE_ORIGIN_REJECTED",
        "X2N_NATIVE_MESSAGE_TOO_LARGE",
        "X2N_NATIVE_ACTION_UNKNOWN",
        "X2N_NATIVE_DUPLICATE_REQUEST",
        "X2N_CANONICAL_KEY_INVALID",
        "X2N_RELATION_KEY_INVALID",
        "X2N_ARTIFACT_VERSION_CONFLICT",
        "X2N_PROVENANCE_INCOMPLETE",
        "X2N_CDN_PERSISTENCE_BLOCKED",
        "X2N_URL_REJECTED",
        "X2N_SECURITY_INJECTION_BLOCKED",
        "X2N_ADAPTER_AUTH_EXPIRED",
        "X2N_PLATFORM_CHANGED",
        "X2N_RATE_LIMITED",
        "X2N_NETWORK_FAILED",
        "X2N_DEPENDENCY_MISSING",
        "X2N_PROVIDER_FAILED",
        "X2N_STORAGE_FAILED",
        "X2N_DATA_INTEGRITY_FAILED",
        "X2N_POLICY_BLOCKED",
        "X2N_UNKNOWN_FAILURE"
      ],
      "title": "ErrorCode",
      "type": "string"
    },
    "FieldProvenance": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "field": {
          "$ref": "#/$defs/CanonicalField"
        },
        "source": {
          "$ref": "#/$defs/FieldSource"
        },
        "status": {
          "$ref": "#/$defs/FieldStatus"
        }
      },
      "required": [
        "field",
        "source",
        "status"
      ],
      "title": "FieldProvenance",
      "type": "object"
    },
    "FieldSource": {
      "enum": [
        "dom",
        "adapter",
        "owner",
        "derived"
      ],
      "title": "FieldSource",
      "type": "string"
    },
    "FieldStatus": {
      "enum": [
        "present",
        "unavailable",
        "unknown"
      ],
      "title": "FieldStatus",
      "type": "string"
    },
    "SourceMethod": {
      "enum": [
        "current_page",
        "selected_collection",
        "adapter_supplement"
      ],
      "title": "SourceMethod",
      "type": "string"
    }
  },
  "$id": "urn:x2n:contract:1.0:source_observation",
  "additionalProperties": false,
  "properties": {
    "adapter_name": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Adapter Name",
      "type": "string"
    },
    "adapter_version": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Adapter Version",
      "type": "string"
    },
    "completeness": {
      "maximum": 1,
      "minimum": 0,
      "title": "Completeness",
      "type": "number"
    },
    "content_key": {
      "maxLength": 768,
      "minLength": 3,
      "title": "Content Key",
      "type": "string"
    },
    "ephemeral_media_ref_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
        "type": "string"
      },
      "title": "Ephemeral Media Ref Ids",
      "type": "array"
    },
    "field_provenance": {
      "items": {
        "$ref": "#/$defs/FieldProvenance"
      },
      "minItems": 1,
      "title": "Field Provenance",
      "type": "array"
    },
    "normalized_fields": {
      "items": {
        "$ref": "#/$defs/CanonicalField"
      },
      "minItems": 1,
      "title": "Normalized Fields",
      "type": "array"
    },
    "observation_id": {
      "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
      "title": "Observation Id",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "raw_text_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Raw Text Hash",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_]{1,31}_[A-Za-z0-9][A-Za-z0-9._-]{0,191}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_method": {
      "$ref": "#/$defs/SourceMethod"
    },
    "warning_codes": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ErrorCode"
      },
      "title": "Warning Codes",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "observation_id",
    "content_key",
    "adapter_name",
    "adapter_version",
    "source_method",
    "observed_at",
    "raw_text_hash",
    "normalized_fields",
    "field_provenance",
    "completeness",
    "run_id"
  ],
  "title": "SourceObservation",
  "type": "object",
  "x-x2n-compatibility": "exact_match_fail_closed",
  "x-x2n-contract-version": "1.0"
}
