  ENTITY {
    uuid id PK
    string canonical_name
    string entity_type
    string status
  }
  RELATIONSHIP {
    uuid id PK
    uuid source_entity_id FK
    uuid target_entity_id FK
    string family
    string relationship_type
    string status
    datetime valid_from
    datetime valid_to
  }
  SUPPLY_CHAIN_ATTRIBUTE {
    uuid relationship_id PK
    string stage_id
    string tier
    decimal materiality
    decimal substitutability
    decimal bottleneck_score
  }
  EXPLORATION_SESSION {
    uuid id PK
    uuid current_focus_entity_id FK
    json state
    datetime updated_at
  }
  EXPLORATION_STEP {
    uuid id PK
    uuid session_id FK
    uuid from_entity_id FK
    uuid to_entity_id FK
    json inherited_state
    integer sequence_no
  }
  SCORING_PROFILE_VERSION {
    uuid id PK
    uuid profile_id FK
    integer version
    json weights
    json half_lives
    string status
  }
  SCORE_RESULT {
    uuid id PK
    uuid scoring_run_id FK
    uuid entity_id FK
    decimal raw_score
    decimal quality_factor
    decimal adjusted_score
    json explanation
  }
  OPERATION_LOG {
    uuid id PK
    string action_type
    string object_type
    uuid object_id
    json old_value
    json new_value
    string reason
    datetime occurred_at
  }
  CALIBRATION_RUN {
    uuid id PK
    datetime as_of
    integer cadence_days
    string status
    json proposal
  }
