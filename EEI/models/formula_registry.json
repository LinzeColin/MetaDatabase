[
  {
    "formula_id": "F-EQ-001",
    "name_zh": "证据质量",
    "name_en": "Evidence Quality",
    "formula": "0.28*source_authority + 0.18*locator_precision + 0.14*temporal_fit + 0.16*cross_source_confirmation + 0.12*source_independence + 0.12*entity_resolution_quality",
    "output_range": "0..100",
    "purpose": "衡量证据可信度与可定位性",
    "missing_policy": "renormalize_available",
    "online_edit": "component_weights",
    "default_threshold": "minimum quality >= 55; inferred relation sources >= 2"
  },
  {
    "formula_id": "F-RF-001",
    "name_zh": "时间相关性",
    "name_en": "Recency Factor",
    "formula": "exp(-ln(2) * age_days / half_life_days)",
    "output_range": "0..1",
    "purpose": "按信息类型衰减时间贡献",
    "missing_policy": "use_observed_at_or_disclose_unknown",
    "online_edit": "half_life_days",
    "default_threshold": "30..1825 days"
  },
  {
