{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BSS v20 independent provider attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_version",
    "attestation_id",
    "start_challenge_sha256",
    "validated_subject",
    "validation_command",
    "validation_exit_code",
    "validation_stdout",
    "validation_stdout_sha256",
    "provider_observation",
    "expected_answer_or_diagnosis_received",
    "verdict"
  ],
  "properties": {
    "attestation_version": {
      "const": "1.0"
    },
    "attestation_id": {
      "const": "BSS-S3-P3-T010-provider-attestation-v20"
    },
    "start_challenge_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "validated_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "v19_result_sha256",
        "v19_raw_sha256",
        "validator_sha256"
      ],
      "properties": {
        "v19_result_sha256": {
          "const": "81bf9815e21ca291702bfb1bb85f68854ff66efa1f5d2a988157838a92fe92d1"
        },
        "v19_raw_sha256": {
          "const": "f6694a5142c20f9ddc1f3a2a9a8ec0702dd454773c1b68152c9539af7a39d6ad"
        },
        "validator_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "validation_command": {
      "const": "python3 -B scripts/validate_forward_test.py --skill-root ."
    },
    "validation_exit_code": {
      "const": 0
    },
    "validation_stdout": {
      "const": "PASS: independent forward test; context=30; trials=19; judges=2; score=23/24"
    },
    "validation_stdout_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "provider_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "context_file_count",
        "executor_trial_count",
        "judge_count",
        "score",
        "maximum_score"
      ],
      "properties": {
        "status": {
          "const": "PASS"
        },
        "context_file_count": {
          "const": 30
        },
        "executor_trial_count": {
          "const": 19
        },
        "judge_count": {
          "const": 2
        },
        "score": {
          "const": 23
        },
        "maximum_score": {
          "const": 24
        }
      }
    },
    "expected_answer_or_diagnosis_received": {
      "const": false
    },
    "verdict": {
      "const": "PASS"
    }
  }
}
