{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abd.local/schemas/infra-config-v0.0.0.1.json",
  "title": "ABD 0.0.0.1 infrastructure reconstruction configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "product_version",
    "deployment_id",
    "host",
    "budget",
    "image",
    "network",
    "directories",
    "secrets",
    "runtime",
    "runtime_prerequisites",
    "activation_requested"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "product_version": {
      "const": "0.0.0.1"
    },
    "deployment_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "region",
        "plan",
        "operating_system",
        "vcpu",
        "memory_mib",
        "disk_gib",
        "capacity_verification_status"
      ],
      "properties": {
        "provider": {
          "const": "OVHcloud"
        },
        "region": {
          "const": "Singapore"
        },
        "plan": {
          "const": "VPS-1"
        },
        "operating_system": {
          "const": "Ubuntu Linux"
        },
        "vcpu": {
          "type": "integer",
          "minimum": 2
        },
        "memory_mib": {
          "type": "integer",
          "minimum": 4096
        },
        "disk_gib": {
          "type": "integer",
          "minimum": 40
        },
        "capacity_verification_status": {
          "enum": [
            "DECLARED_TARGET_NOT_ACCOUNT_VERIFIED",
            "VERIFIED_ON_TARGET_HOST"
          ]
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "incremental_cash_aud",
        "new_instance_allowed",
        "paid_upgrade_allowed",
        "automatic_overage_allowed"
      ],
      "properties": {
        "incremental_cash_aud": {
          "const": "0.00"
        },
        "new_instance_allowed": {
          "const": false
        },
        "paid_upgrade_allowed": {
          "const": false
        },
        "automatic_overage_allowed": {
          "const": false
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "pull_policy",
        "build_or_pull_performed_in_p01"
      ],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:/-]*@sha256:[a-f0-9]{64}$"
        },
        "pull_policy": {
          "const": "never"
        },
        "build_or_pull_performed_in_p01": {
          "const": false
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bind_address",
        "bind_port",
        "public_business_inbound_enabled",
        "cloudflare_tunnel_configured_in_p01"
      ],
      "properties": {
        "bind_address": {
          "const": "127.0.0.1"
        },
        "bind_port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535
        },
        "public_business_inbound_enabled": {
          "const": false
        },
        "cloudflare_tunnel_configured_in_p01": {
          "const": false
        }
      }
    },
    "directories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "state",
        "logs",
        "secrets",
        "releases"
      ],
      "properties": {
        "config": {
          "const": "/etc/abd"
        },
        "state": {
          "const": "/var/lib/abd"
        },
        "logs": {
          "const": "/var/log/abd"
        },
        "secrets": {
          "const": "/etc/abd/secrets"
        },
        "releases": {
          "const": "/opt/abd/releases"
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_secret_file",
        "inline_secret_values_present",
        "repository_secret_files"
      ],
      "properties": {
        "runtime_secret_file": {
          "type": "string",
          "pattern": "^/etc/abd/secrets/[A-Za-z0-9._-]+$"
        },
        "inline_secret_values_present": {
          "const": false
        },
        "repository_secret_files": {
          "type": "array",
          "maxItems": 0
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uid_gid",
        "cpus",
        "memory_limit_mib",
        "memory_reservation_mib",
        "pids_limit",
        "read_only_root",
        "no_new_privileges",
        "swap_disabled",
        "order_submission_enabled"
      ],
      "properties": {
        "uid_gid": {
          "type": "string",
          "pattern": "^[1-9][0-9]{2,5}:[1-9][0-9]{2,5}$"
        },
        "cpus": {
          "const": "1.50"
        },
        "memory_limit_mib": {
          "const": 2560
        },
        "memory_reservation_mib": {
          "const": 1024
        },
        "pids_limit": {
          "const": 512
        },
        "read_only_root": {
          "const": true
        },
        "no_new_privileges": {
          "const": true
        },
        "swap_disabled": {
          "const": true
        },
        "order_submission_enabled": {
          "const": false
        }
      }
    },
    "runtime_prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_host_access",
        "docker_compose",
        "systemd",
        "image_availability",
        "secret_files"
      ],
      "properties": {
        "target_host_access": {
          "enum": [
            "NOT_EXECUTED",
            "VERIFIED"
          ]
        },
        "docker_compose": {
          "enum": [
            "NOT_EXECUTED",
            "VERIFIED"
          ]
        },
        "systemd": {
          "enum": [
            "NOT_EXECUTED",
            "VERIFIED"
          ]
        },
        "image_availability": {
          "enum": [
            "NOT_EXECUTED",
            "VERIFIED"
          ]
        },
        "secret_files": {
          "enum": [
            "NOT_EXECUTED",
            "VERIFIED"
          ]
        }
      }
    },
    "activation_requested": {
      "const": false
    }
  }
}
