  "stage_id": "S03",
  "phase_id": "P01",
  "policy_id": "UI-TERMINOLOGY-ZH-ONLY-V1",
  "default_action": "BLOCK_UNREGISTERED_OR_UNEXPLAINED_TOKEN",
  "included_surface_kinds": [
    "DAILY_HOME",
    "ADVICE_CARD",
    "EVIDENCE_STATUS",
    "ACCOUNT_MAIL_STATUS",
    "USER_ERROR_NEXT_ACTION"
  ],
  "non_rendered_machine_exemption": {
    "surface_kind": "NON_RENDERED_MACHINE_RECORD",
    "condition": "内容只存在于源代码、机器字段、结构化证据或运维日志且绝不被渲染到用户界面。",
    "rendered_content_must_reenter_ui_gate": true
  },
  "generic_forbidden_patterns": [
    {
      "pattern_id": "PATTERN-UPPERCASE-ACRONYM",
      "regex": "(?<![A-Za-z0-9])(?:[A-Z]{2,}(?:[-_/][A-Z0-9]+)*)(?![A-Za-z0-9])",
      "reason_code": "UI_TERM_UNREGISTERED_RAW_TOKEN"
    },
    {
      "pattern_id": "PATTERN-INTERNAL-ID",
      "regex": "(?<![A-Za-z0-9])(?:REQ|AC|TEST|EVD|ART|INDEX)-[A-Za-z0-9_/-]+",
      "reason_code": "UI_TERM_INTERNAL_IDENTIFIER"
    },
    {
      "pattern_id": "PATTERN-SNAKE-CASE",
      "regex": "(?<![A-Za-z0-9])(?:[a-z]+_[a-z0-9_]+)(?![A-Za-z0-9])",
      "reason_code": "UI_TERM_MACHINE_IDENTIFIER"
    }
  ],
  "reason_codes": {
    "UI_TERM_UNREGISTERED_RAW_TOKEN": "发现未登记的英文缩写或机器词；改为中文或先加入字典并完成解释合同。",
    "UI_TERM_INTERNAL_IDENTIFIER": "发现需求、验收、测试、证据或制品内部编号；用户界面只显示中文含义。",
    "UI_TERM_MACHINE_IDENTIFIER": "发现机器字段名；将其映射为字典中的中文标签后再展示。",
    "UI_TERM_UNEXPLAINED": "缩写已登记但当前文字没有按规定解释；使用精确首次展示形式或纯中文标签。",
    "UI_TERM_ZH_ONLY": "该词只允许显示中文名称。",
    "UI_TERM_MACHINE_ONLY": "该词仅供机器或运维使用，不得出现在日常用户界面。",
    "UI_SURFACE_UNKNOWN": "界面类型未登记；在纳入扫描范围前失败关闭。"
  },
