{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abd.local/schemas/acceptance.schema.json",
  "title": "ABD验收合同",
  "type": "object",
  "required": [
    "id",
    "requirement_id",
    "title",
    "environment",
    "inputs",
    "oracle",
    "threshold",
    "tests",
    "evidence_requirements",
    "pass_gate",
    "stop_condition",
    "rollback",
    "retention"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AC-S[0-9]{2}-P[0-9]{2}$"
    },
    "requirement_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "environment": {
      "type": "array",
      "minItems": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1
    },
    "oracle": {
      "type": "object",
      "required": [
        "type",
        "command",
        "rule"
      ]
    },
    "threshold": {
      "type": "string"
    },
    "tests": {
      "type": "array",
      "minItems": 1
    },
    "evidence_requirements": {
      "type": "array",
      "minItems": 1
    },
    "pass_gate": {
      "type": "string"
    },
    "stop_condition": {
      "type": "array",
      "minItems": 1
    },
    "rollback": {
      "type": "string"
    },
    "retention": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
