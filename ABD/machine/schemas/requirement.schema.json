{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abd.local/schemas/requirement.schema.json",
  "title": "ABD需求合同",
  "type": "object",
  "required": [
    "id",
    "stage_id",
    "phase_id",
    "title",
    "problem",
    "user",
    "value",
    "scope",
    "non_goals",
    "baseline",
    "target",
    "measurement",
    "observation_period",
    "primary_acceptance_criteria_id",
    "priority",
    "owner_input_required_during_development"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-S[0-9]{2}-P[0-9]{2}$"
    },
    "stage_id": {
      "type": "string"
    },
    "phase_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "problem": {
      "type": "string"
    },
    "user": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "scope": {
      "type": "array"
    },
    "non_goals": {
      "type": "array"
    },
    "baseline": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "measurement": {
      "type": "string"
    },
    "observation_period": {
      "type": "string"
    },
    "primary_acceptance_criteria_id": {
      "type": "string"
    },
    "priority": {
      "type": "string"
    },
    "owner_input_required_during_development": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
