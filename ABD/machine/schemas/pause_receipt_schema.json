{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abd.local/schemas/pause_receipt_schema.json",
  "title": "ABD 最小暂停回执",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "product_version",
    "status",
    "pause_reason_code",
    "scope",
    "detected_at",
    "minimal_decision_question",
    "evidence",
    "default_recommendation",
    "no_decision_consequence",
    "incremental_cash_cost_aud",
    "secret_material_present"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^PAUSE-[A-Z0-9-]{3,80}$"
    },
    "product_version": {
      "const": "0.0.0.1"
    },
    "status": {
      "const": "OPEN"
    },
    "pause_reason_code": {
      "enum": [
        "LEGAL_REGULATORY_SOURCE_CONFLICT",
        "SECURITY_OR_SUPPLY_CHAIN_INCIDENT",
        "ACTUAL_LEDGER_RECONCILIATION_FAILURE",
        "IRREVERSIBLE_OPERATION",
        "INCREMENTAL_CASH_BUDGET_EXCEEDED",
        "OUT_OF_AUTHORIZED_SCOPE",
        "TERMINATION_CONDITION_TRIGGERED"
      ]
    },
    "scope": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "minimal_decision_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "default_recommendation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "no_decision_consequence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "incremental_cash_cost_aud": {
      "const": "0.00"
    },
    "secret_material_present": {
      "const": false
    }
  },
  "$defs": {
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "artifact", "sha256", "summary"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "kind": {
          "enum": ["FACT", "SOURCE", "TEST", "LOG", "ARTIFACT", "INCIDENT"]
        },
        "artifact": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300,
          "pattern": "^(?!/)(?!.*\\.\\.).+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  },
  "x-canonical-field-map": {
    "最小决策问题": "minimal_decision_question",
    "证据": "evidence",
    "默认建议": "default_recommendation",
    "不决策后果": "no_decision_consequence"
  }
}
