+                   "replayed_key_hash": s["key_hash"], "matches_committed": s["matches_committed"],
+                   "deterministic": s["deterministic"]} for s in rep["stages"]],
+    "committed_anchors": {"registry_hash": R.COMMITTED_REGISTRY_HASH,
