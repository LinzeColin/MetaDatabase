+# -> ACCEPTANCE = PASS (exit 0)
+
+# 3) committed evidence
+python3 tools/duckdb_verify.py --snapshot-dir <t028_snap> --out evidence/ADP-S2-P03-T028/rebuild_report.json --sql-out evidence/ADP-S2-P03-T028/sample_queries.sql
