+          f"{sum(1 for p in P0_ACCEPTANCE if p['status']=='OWNER_WAIVER')} OWNER_WAIVER; all_ok={m['all_p0_pass_or_waived']}")
+    print(f"manifest {m['manifest_sha256'][:26]}")
+    return 0
+
+
+if __name__ == "__main__":
+    import sys
+    sys.exit(main())
