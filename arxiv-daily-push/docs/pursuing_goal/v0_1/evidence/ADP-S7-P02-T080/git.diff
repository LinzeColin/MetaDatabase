+// ───────────────────────── 板块浏览 /board/:id ─────────────────────────
+async function boardPage(env, boardId, offset) {
+  const board = REGISTRY.find(b => b.board === boardId) || (boardId === 'board5' ? AGG_BOARD : null);
+  if (!board) return null;
