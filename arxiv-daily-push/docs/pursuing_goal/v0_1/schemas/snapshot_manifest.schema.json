{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "adp/v0_1/schemas/snapshot_manifest.schema.json",
  "title": "ADP Monthly Snapshot Manifest (ADP-S2-P03-T027)",
  "type": "object",
  "required": ["snapshot_spec_version", "snapshot_id", "format", "engine", "generated_from", "schemas", "totals", "partitions"],
  "additionalProperties": true,
  "properties": {
    "snapshot_spec_version": {"type": "string", "const": "adp.snapshot.v0_1"},
    "snapshot_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "format": {"type": "string", "enum": ["parquet", "ndjson"]},
    "engine": {"type": "string"},
    "generated_from": {"type": "string"},
    "reproducibility": {"type": "string"},
    "schemas": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["schema_version", "columns"],
        "properties": {
          "schema_version": {"type": "string", "pattern": "^v[0-9]+$"},
          "columns": {"type": "array", "items": {"type": "array", "minItems": 2, "maxItems": 2,
            "items": [{"type": "string"}, {"type": "string", "enum": ["string", "int64"]}]}}
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["cn_documents", "cn_document_versions", "months", "partitions"],
      "properties": {
        "cn_documents": {"type": "integer", "minimum": 0},
        "cn_document_versions": {"type": "integer", "minimum": 0},
        "months": {"type": "array", "items": {"type": "string", "pattern": "^([0-9]{4}-[0-9]{2}|unknown)$"}},
        "partitions": {"type": "integer", "minimum": 0}
      }
    },
    "canonicalize_summary": {"type": "object"},
    "partitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table", "month", "rows", "schema_version", "logical_hash", "path", "physical_sha256", "bytes"],
        "additionalProperties": false,
        "properties": {
          "table": {"type": "string", "enum": ["cn_documents", "cn_document_versions"]},
          "month": {"type": "string", "pattern": "^([0-9]{4}-[0-9]{2}|unknown)$"},
          "rows": {"type": "integer", "minimum": 0},
          "schema_version": {"type": "string", "pattern": "^v[0-9]+$"},
          "logical_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "path": {"type": "string", "pattern": "^data/(cn_documents|cn_document_versions)__([0-9]{4}-[0-9]{2}|unknown)\\.(parquet|ndjson)$"},
          "physical_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
