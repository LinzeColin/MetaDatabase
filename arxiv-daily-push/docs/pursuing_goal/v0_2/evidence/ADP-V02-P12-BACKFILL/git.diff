+    setCursor: (v) => env.DB.prepare("INSERT INTO cn_meta (key,value) VALUES ('backfill_from',?) ON CONFLICT(key) DO UPDATE SET value=excluded.value").bind(v).run(),
+    today: dayISO(), START: BACKFILL_START, PAGES: BACKFILL_PAGES, SPAN_DAYS: BACKFILL_SPAN_DAYS, degraded,
+  });
