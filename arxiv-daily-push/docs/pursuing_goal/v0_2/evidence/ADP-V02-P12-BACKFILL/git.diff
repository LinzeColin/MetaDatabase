+    return { error: e && e.name || 'err' };
+  }
+}
+//@P12-CORE-END
+async function fetchBackfillPage(from, until) {
+  const url = `https://export.arxiv.org/oai2?verb=ListRecords&metadataPrefix=arXiv&from=${from}&until=${until}`;
+  const r = await fetch(url, { headers: { 'User-Agent': UA }, signal: AbortSignal.timeout(20000) });
+  if (r.status === 503) return { items: [], token: null, busy: true };   // OAI 忙：本夜跳过、不推进游标
+  if (!r.ok) throw new Error('http' + r.status);
+  return parseOaiArxiv(await r.text());   // {items, token}
+}
+// 薄壳：把真实 D1/OAI 依赖注入上面被测的 runBackfill 核心。与当日流水线隔离——在 scheduled 里
