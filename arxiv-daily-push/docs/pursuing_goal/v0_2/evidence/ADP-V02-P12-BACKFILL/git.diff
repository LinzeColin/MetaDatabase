+//@P12-CORE-START
+function nextBackfillFrom(tokenValue) {   // OAI resumptionToken 无状态，值里编码了下一段 from=YYYY-MM-DD
+  if (!tokenValue) return null;
+  let dec; try { dec = decodeURIComponent(tokenValue); } catch { dec = String(tokenValue); }
+  const m = dec.match(/from=(\d{4}-\d{2}-\d{2})/);
+  return m ? m[1] : null;
+}
+function advanceCursor(cursor, tokenValue, until) {
+  const cand = nextBackfillFrom(tokenValue) || until;
+  return cand > cursor ? cand : cursor;   // ★单调★：只进不退（P09/P10 都栽过「反复确认同一批」）
+}
+function backfillWindow(cursor, today, spanDays) {
+  const d = new Date(cursor + 'T00:00:00Z'); d.setUTCDate(d.getUTCDate() + spanDays);
+  const capped = d.toISOString().slice(0, 10);
+  return { from: cursor, until: capped < today ? capped : today };   // 不越 today；近端由每日 cron 负责
+}
+function plusDaysISO(dateStr, n) {
+  const d = new Date(dateStr + 'T00:00:00Z'); d.setUTCDate(d.getUTCDate() + n);
+  return d.toISOString().slice(0, 10);
+}
+// 编排核心：依赖全部注入（fetchPage/insertItems/get|setCursor），故可用真 node:sqlite + mock OAI 单测。
+async function runBackfill({ fetchPage, insertItems, getCursor, setCursor, today, START, PAGES, SPAN_DAYS, degraded }) {
+  try {
+    let cursor = (await getCursor()) || START;
+    if (cursor >= today) return { skipped: 'caught_up', cursor };  // 已追平近端，交给每日 cron
+    const { from, until } = backfillWindow(cursor, today, SPAN_DAYS);
+    let token = null, rows = 0, pages = 0, curFrom = from, busy = false;
+    for (pages = 0; pages < PAGES; pages++) {                       // ★页封顶 = 子请求/CPU 预算（DIR-007）★
+      const { items, nextToken, busy: b } = await fetchPage(curFrom, until, token);
+      if (b) { busy = true; break; }                               // OAI 忙(503)：★不推进游标★，下夜重试同窗口
+      await insertItems(items);                                    // published_at=created→正确格；ON CONFLICT 去重
+      rows += items.length;
+      token = nextToken;
+      if (!token) break;                                           // 窗口取尽
+      curFrom = nextBackfillFrom(token) || curFrom;
+    }
