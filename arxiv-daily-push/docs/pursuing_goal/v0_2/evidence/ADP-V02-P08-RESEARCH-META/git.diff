+  if ((m = /\/doi\/(?:full\/|abs\/|pdf\/)?(10\.\d{4,9}\/[^?#\s]{1,80})/.exec(url))) return metaNotAsset(m[1]);
+  if ((m = /[?&]id=(10\.\d{4,9}\/[^&#\s]{1,80})/.exec(url))) return metaNotAsset(m[1]);
