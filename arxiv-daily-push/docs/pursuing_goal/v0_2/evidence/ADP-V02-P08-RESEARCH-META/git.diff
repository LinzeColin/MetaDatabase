+// 复核指出原实现会返回 10.1371/journal.pbio.3003906.PDF —— 那是**猜**。抽不准就弃权。
+function metaNotAsset(doi) { return /\.(?:pdf|xml|docx?|zip|csv|tiff?|png|jpe?g|s\d{3})$/i.test(doi) ? null : doi; }
