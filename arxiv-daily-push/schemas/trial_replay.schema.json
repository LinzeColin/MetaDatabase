{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/arxiv-daily-push/schemas/trial_replay.schema.json",
  "title": "arXiv Daily Push Trial Replay Evidence Report",
  "type": "object",
  "required": [
    "replay_report_id",
    "model_id",
    "project_id",
    "generated_at",
    "status",
    "trial_id",
    "timezone",
    "expected_days",
    "requested_replay_modes",
    "replay_evidence_verified",
    "weekly_replay_verified",
    "monthly_replay_verified",
    "replay_evidence_ref",
    "observed_day_count",
    "date_range",
    "coverage",
    "daily_entry_refs",
    "annotation_hint",
    "blocking_reasons"
  ],
  "properties": {
    "replay_report_id": {"type": "string", "minLength": 1},
    "model_id": {"const": "adp-trial-replay-v1"},
    "project_id": {"const": "arxiv-daily-push"},
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["pass", "blocked"]},
    "trial_id": {"type": "string", "minLength": 1},
    "timezone": {"type": "string", "minLength": 1},
    "expected_days": {"type": "integer", "minimum": 1},
    "requested_replay_modes": {"type": "object"},
    "replay_evidence_verified": {"type": "boolean"},
    "weekly_replay_verified": {"type": "boolean"},
    "monthly_replay_verified": {"type": "boolean"},
    "replay_evidence_ref": {"type": "string"},
    "observed_day_count": {"type": "integer", "minimum": 0},
    "date_range": {"type": "object"},
    "coverage": {"type": "object"},
    "daily_entry_refs": {"type": "array", "items": {"type": "object"}},
    "annotation_hint": {"type": "object"},
    "blocking_reasons": {"type": "array", "items": {"type": "string"}},
    "validation_errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
