{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/arxiv-daily-push/schemas/storyboard.schema.json",
  "title": "Storyboard",
  "type": "object",
  "required": ["storyboard_id", "lesson_id", "scenes", "constraints", "generated_at"],
  "properties": {
    "storyboard_id": {"type": "string", "minLength": 1},
    "lesson_id": {"type": "string", "minLength": 1},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "duration_sec", "narration", "visual_plan", "claim_ids"],
        "properties": {
          "scene_id": {"type": "string"},
          "duration_sec": {"type": "number", "minimum": 0},
          "narration": {"type": "string"},
          "visual_plan": {"type": "string"},
          "claim_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "constraints": {"type": "object", "additionalProperties": true},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": false
}
