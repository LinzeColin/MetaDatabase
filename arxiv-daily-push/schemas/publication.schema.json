{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/arxiv-daily-push/schemas/publication.schema.json",
  "title": "Publication",
  "type": "object",
  "required": ["publication_id", "run_id", "publication_type", "status", "artifacts", "created_at"],
  "properties": {
    "publication_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "publication_type": {"type": "string", "enum": ["daily", "weekly", "monthly", "manual_replay"]},
    "status": {"type": "string", "enum": ["draft", "blocked", "ready", "published", "degraded", "failed"]},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "path", "sha256"],
        "properties": {
          "artifact_type": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "release_url": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
