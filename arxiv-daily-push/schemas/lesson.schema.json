{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/arxiv-daily-push/schemas/lesson.schema.json",
  "title": "Lesson",
  "type": "object",
  "required": ["lesson_id", "source_item_id", "language", "title", "sections", "claim_ids", "generated_at"],
  "properties": {
    "lesson_id": {"type": "string", "minLength": 1},
    "source_item_id": {"type": "string", "minLength": 1},
    "language": {"type": "string", "enum": ["zh-CN", "zh-Hans", "en"]},
    "title": {"type": "string", "minLength": 1},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section_id", "title", "body", "claim_ids"],
        "properties": {
          "section_id": {"type": "string"},
          "title": {"type": "string"},
          "body": {"type": "string"},
          "claim_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "claim_ids": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": false
}
