{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LinzeColin/CodexProject/arxiv-daily-push/schemas/narration.schema.json",
  "title": "Narration",
  "type": "object",
  "required": ["narration_id", "lesson_id", "language", "tts_mode", "audio_synthesis_allowed", "segments", "claim_ids", "resource_gate", "generated_at"],
  "properties": {
    "narration_id": {"type": "string", "minLength": 1},
    "lesson_id": {"type": "string", "minLength": 1},
    "language": {"type": "string", "enum": ["zh-CN", "zh-Hans", "en"]},
    "tts_mode": {"type": "string", "enum": ["dry_run"]},
    "audio_synthesis_allowed": {"type": "boolean"},
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segment_id", "section_id", "text", "duration_estimate_sec", "claim_ids"],
        "properties": {
          "segment_id": {"type": "string"},
          "section_id": {"type": "string"},
          "text": {"type": "string"},
          "duration_estimate_sec": {"type": "integer", "minimum": 0},
          "claim_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "claim_ids": {"type": "array", "items": {"type": "string"}},
    "resource_gate": {"type": "object", "additionalProperties": true},
    "generated_at": {"type": "string"}
  },
  "additionalProperties": false
}
