EEI_ENV=local
EEI_API_HOST=127.0.0.1
EEI_API_PORT=8000
EEI_WEB_PORT=3000
EEI_SAVED_VIEW_IDENTITY_MODE=local
# Required when EEI_ENV=production or EEI_SAVED_VIEW_IDENTITY_MODE=trusted_gateway.
# The upstream identity gateway must use this secret to sign saved-view identity headers.
EEI_SAVED_VIEW_GATEWAY_SECRET=
EEI_SAVED_VIEW_SIGNATURE_TTL_SECONDS=300
POSTGRES_DB=eei
POSTGRES_USER=eei
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgresql://eei:change-me-local-only@127.0.0.1:5432/eei
