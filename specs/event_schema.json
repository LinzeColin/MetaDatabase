{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/corporate-event.json",
  "title": "CorporateEvent",
  "type": "object",
  "required": [
    "id",
    "event_type",
    "title",
    "status",
    "observed_at",
    "participants",
    "evidence"
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "investment",
        "funding_round",
        "acquisition",
        "contract_award",
        "capital_expenditure",
        "share_repurchase",
        "insider_transaction",
        "partnership",
        "facility_build",
        "regulatory_action",
        "other"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "reported",
        "derived",
        "disputed",
        "superseded",
        "revoked",
        "unknown"
      ]
    },
    "announced_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "effective_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "period_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "period_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "amount": {
      "type": [
        "number",
        "null"
      ]
    },
    "currency": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Z]{3}$"
    },
    "amount_kind": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "announced_investment",
        "committed_capital",
        "cash_invested",
        "transaction_value",
        "valuation",
        "award_ceiling",
        "obligation",
        "outlay",
        "period_capex",
        "repurchase_authorization",
        "other"
      ]
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "entity_id",
          "role"
        ],
        "properties": {
          "entity_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          },
          "direction": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "in",
              "out",
              "bidirectional"
            ]
          }
        }
      }
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_document_id",
          "role"
        ],
        "properties": {
          "source_document_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": [
              "supports",
              "contradicts",
              "context"
            ]
          },
          "locator": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "qualifiers": {
      "type": "object",
      "additionalProperties": true
    },
    "id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "amount": {
            "type": "number"
          }
        },
        "required": [
          "amount"
        ]
      },
      "then": {
        "required": [
          "currency",
          "amount_kind"
        ]
      }
    }
  ],
  "additionalProperties": false
}
